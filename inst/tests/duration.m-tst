## 'ismember'         'ismissing'        'isnan'            'isregular'       ##
## 'isrow'            'isscalar'         'issorted'         'issortedrows'    ##
## 'isvector'                                                                 ##
##                                                                            ##
################################################################################

%!test
%! TF = isbetween (days ([0:5]), days (2), days (3));
%! assert (TF, logical ([0, 0, 1, 1, 0, 0,]));
%!test
%! TF = isbetween (days ([0:5]), duration ('02:00:00:00'), days (3));
%! assert (TF, logical ([0, 0, 1, 1, 0, 0,]));
%!test
%! TF = isbetween (days ([0:5]), duration ("1:00:00:00"), days (3));
%! assert (TF, logical ([0, 1, 1, 1, 0, 0,]));
%!test
%! TF = isbetween (days ([0:5]), duration ("1:00:00:00"), days (4));
%! assert (TF, logical ([0, 1, 1, 1, 1, 0,]));
%!test
%! TF =  isbetween (days ([0:5]), days (2), days (3), 'open');
%! assert (TF, false (1, 6));
%!test
%! TF = isbetween (days ([0:5]), duration ('02:00:00:00'), days (3), 'open');
%! assert (TF, false (1, 6));
%!test
%! TF = isbetween (days ([0:5]), duration ('01:00:00:00'), days (3), 'open');
%! assert (TF, logical ([0, 0, 1, 0, 0, 0,]));
%!test
%! TF = isbetween (days ([0:5]), duration ('01:00:00:00'), days (4), 'open');
%! assert (TF, logical ([0, 0, 1, 1, 0, 0,]));
%!test
%! TF = isbetween (days ([0:5]), days (2), hours (72), 'open');
%! assert (TF, false (1, 6));
%!test
%! TF =  isbetween (days ([0:5]), days (2), days (3), 'openleft');
%! assert (TF, logical ([0, 0, 0, 1, 0, 0,]));
%!test
%! TF = isbetween (days ([0:5]), duration ('02:00:00:00'), days (3), 'openleft');
%! assert (TF, logical ([0, 0, 0, 1, 0, 0,]));
%!test
%! TF = isbetween (days ([0:5]), duration ('01:00:00:00'), days (3), 'openleft');
%! assert (TF, logical ([0, 0, 1, 1, 0, 0,]));
%!test
%! TF = isbetween (days ([0:5]), duration ('01:00:00:00'), days (4), 'openleft');
%! assert (TF, logical ([0, 0, 1, 1, 1, 0,]));
%!test
%! TF = isbetween (days ([0:5]), days (2), hours (72), 'openleft');
%! assert (TF, logical ([0, 0, 0, 1, 0, 0,]));
%!test
%! TF =  isbetween (days ([0:5]), days (2), days (3), 'closedleft');
%! assert (TF, logical ([0, 0, 1, 0, 0, 0,]));
%!test
%! TF = isbetween (days ([0:5]), duration ('02:00:00:00'), days (3), 'closedleft');
%! assert (TF, logical ([0, 0, 1, 0, 0, 0,]));
%!test
%! TF = isbetween (days ([0:5]), duration ('01:00:00:00'), days (3), 'closedleft');
%! assert (TF, logical ([0, 1, 1, 0, 0, 0,]));
%!test
%! TF = isbetween (days ([0:5]), duration ('01:00:00:00'), days (4), 'closedleft');
%! assert (TF, logical ([0, 1, 1, 1, 0, 0,]));
%!test
%! TF = isbetween (days ([0:5]), days (2), hours (72), 'closedleft');
%! assert (TF, logical ([0, 0, 1, 0, 0, 0,]));
%!test
%! TF = isbetween (days ([0:5]),'1:23:00:00', hours (72));
%! assert (TF, logical ([0, 0, 1, 1, 0, 0,]));
%!assert (isbetween (years (1), years (1), years (1)), true)
%!error<duration.isbetween: too few input arguments.> ...
%! isbetween (days (1), days (1))
%!error<duration.isbetween: optional paired arguments are not suppoorted for duration arrays.> ...
%! isbetween (days (1), days (1), days (1), 'open', 'OutputFormat', 'logical')
%!error<duration.isbetween: LOWER and UPPER cannot be numeric.> ...
%! isbetween (days (1), 1, 2)
%!error<duration.isbetween: invalid INTERVALTYPE option.> ...
%! isbetween (days (1), days (1), days (1), 'asd')

%!assert (iscolumn (days ([1, 2, 3, 4])), false)
%!assert (iscolumn (days ([1; 2; 3; 4])), true)
%!assert (iscolumn (days ([1, 2; 3, 4])), false)
%!assert (iscolumn (days ([])), false)
%!assert (iscolumn (days (ones (1, 0))), false)
%!assert (iscolumn (days (ones (0, 1))), true)
%!assert (iscolumn (days (1)), true)
%!assert (iscolumn (days (ones (2, 3, 4))), false)

%!assert (isempty (days ([])), true)
%!assert (isempty (days (ones (2, 0, 3))), true)
%!assert (isempty (days (ones (2, 1, 3))), false)
%!assert (isempty (days (1)), false)
%!assert (isempty (duration), false)

%!assert (isequal (duration (24, 0, 0), days (1)), true)
%!assert (isequal (duration (24, 0, 0), '24:00:00'), true)
%!assert (isequal (duration (24, 0, 0), '24:00:01'), false)
%!assert (isequal (duration (24, 0, 1), {'24:00:01'}), true)
%!assert (isequal (duration (24, 0, 1), {'24:00:00'}), false)
%!assert (isequal (days ([1, 2]), string ({'24:00:00', '48:00:00'})), true)
%!assert (isequal (days ([1, 2]), string ({'24:00:00'; '48:00:00'})), false)
%!assert (isequal (days ([1; 2]), string ({'24:00:00'; '48:00:00'})), true)
%!assert (isequal (days ([1; 2]), string ({'24:00:00', '48:00:00'})), false)
%!assert (isequal (days (ones (2, 3, 4)), days (ones (2, 3, 4))), true)
%!assert (isequal (duration (ones (2, 3, 4) * 24, 0, 0), days (ones (2, 3, 4))), true)
%!assert (isequal (repmat ({'24:00:00'}, 2, 3, 4), days (ones (2, 3, 4))), true)
%!assert (isequal (repmat ({'24:00:05'}, 2, 3, 4), duration (24 * ones (2, 3, 4), 0, 5)), true)
%!assert (isequal (days (1), duration (24, 0, 0), '24:00:00'), true)
%!assert (isequal (days ([1, NaN]), duration ([24, NaN], 0, 0)), false)

%!assert (isequaln (duration (24, 0, 0), days (1)), true)
%!assert (isequaln (duration (24, 0, 0), '24:00:00'), true)
%!assert (isequaln (duration (24, 0, 0), '24:00:01'), false)
%!assert (isequaln (duration (24, 0, 1), {'24:00:01'}), true)
%!assert (isequaln (duration (24, 0, 1), {'24:00:00'}), false)
%!assert (isequaln (days ([1, 2]), string ({'24:00:00', '48:00:00'})), true)
%!assert (isequaln (days ([1, 2]), string ({'24:00:00'; '48:00:00'})), false)
%!assert (isequaln (days ([1; 2]), string ({'24:00:00'; '48:00:00'})), true)
%!assert (isequaln (days ([1; 2]), string ({'24:00:00', '48:00:00'})), false)
%!assert (isequaln (days (ones (2, 3, 4)), days (ones (2, 3, 4))), true)
%!assert (isequaln (duration (ones (2, 3, 4) * 24, 0, 0), days (ones (2, 3, 4))), true)
%!assert (isequaln (repmat ({'24:00:00'}, 2, 3, 4), days (ones (2, 3, 4))), true)
%!assert (isequaln (repmat ({'24:00:05'}, 2, 3, 4), duration (24 * ones (2, 3, 4), 0, 5)), true)
%!assert (isequaln (days (1), duration (24, 0, 0), '24:00:00'), true)
%!assert (isequaln (days ([1, NaN]), duration ([24, NaN], 0, 0)), true)

%!assert (isfinite (days ([1, -Inf, NaN, Inf])), [true, false, false, false])
%!assert (isfinite (days ([1, -Inf; NaN, Inf])), [true, false; false, false])
%!assert (isfinite (days (ones (0, 1))), true (0, 1))
%!assert (isfinite (days (ones (1, 0))), true (1, 0))
%!assert (isfinite (days ([])), true ([]))
%!assert (isfinite (duration (ones (2, 3, 4), 0, 0)), true (2, 3, 4))
%!assert (isfinite (duration (Inf (2, 3, 4), 0, 0)), false (2, 3, 4))
%!assert (isfinite (duration (-Inf (2, 3, 4), 0, 0)), false (2, 3, 4))
%!assert (isfinite (duration (NaN (2, 3, 4), 0, 0)), false (2, 3, 4))

%!assert (isinf (days ([1, -Inf, NaN, Inf])), [false, true, false, true])
%!assert (isinf (days ([1, -Inf; NaN, Inf])), [false, true; false, true])
%!assert (isinf (days (ones (0, 1))), true (0, 1))
%!assert (isinf (days (ones (1, 0))), true (1, 0))
%!assert (isinf (days ([])), true ([]))
%!assert (isinf (duration (ones (2, 3, 4), 0, 0)), false (2, 3, 4))
%!assert (isinf (duration (Inf (2, 3, 4), 0, 0)), true (2, 3, 4))
%!assert (isinf (duration (-Inf (2, 3, 4), 0, 0)), true (2, 3, 4))
%!assert (isinf (duration (NaN (2, 3, 4), 0, 0)), false (2, 3, 4))

%!assert (ismatrix (duration), true)
%!assert (ismatrix (duration ([], [], [])), true)
%!assert (ismatrix (duration (ones (2, 4), 0, 0)), true)
%!assert (ismatrix (duration (ones (2, 4, 1), 0, 0)), true)
%!assert (ismatrix (duration (ones (2, 1, 4), 0, 0)), false)
%!assert (ismatrix (duration (ones (2, 3, 4), 0, 0)), false)
%!assert (ismatrix (days (ones (0, 1))), true)
%!assert (ismatrix (days (ones (1, 0))), true)

%!assert (ismember (days (1), days ([1, 2])), true)
%!assert (ismember (days ([1, 2]), days (1)), [true, false])
%!assert (ismember (days ([1; 2]), days (1)), [true; false])
%!assert (ismember (days (1), days ([1; 2])), true)
%!test
%! [TF, index] = ismember (days (1), days (ones (2, 3, 4)));
%! assert (TF, true);
%! assert (index, 1);
%!test
%! [TF, index] = ismember (days (1), days (ones (2, 3, 4)), 'legacy');
%! assert (TF, true);
%! assert (index, 24);
%!test
%! x = ones (2, 3, 4);
%! x(1) = 2;
%! [TF, index] = ismember (days (1), days (x));
%! assert (TF, true);
%! assert (index, 2); # This is MATLAB incompatible
%!test
%! x = ones (2, 3, 4);
%! x(1) = 2;
%! [TF, index] = ismember (days (1), days (x), 'legacy');
%! assert (TF, true);
%! assert (index, 24);
%!test
%! [TF, index] = ismember (days ([0:4]), days ([1, 2]));
%! assert (TF, [false, true, true, false, false]);
%! assert (index, [0, 1, 2, 0, 0]);
%!test
%! [TF, index] = ismember (days ([0:4]), days ([-1, 2]));
%! assert (TF, [false, false, true, false, false]);
%! assert (index, [0, 0, 2, 0, 0]);
%!test
%! [TF, index] = ismember (days ([0:4]), [-1, 2]);
%! assert (TF, [false, false, true, false, false]);
%! assert (index, [0, 0, 2, 0, 0]);
%!test
%! [TF, index] = ismember (days ([0:4]), {'24:00:00', '18:00:00'});
%! assert (TF, [false, true, false, false, false]);
%! assert (index, [0, 1, 0, 0, 0]);
%!test
%! [TF, index] = ismember (days ([2,3;1,2;-1,2;4,5]), days ([-1, 2]), 'rows');
%! assert (TF, [false; false; true; false]);
%! assert (index, [0; 0; 1; 0]);
%!error<duration.ismember: 'rows' applies only to 2-D matrices.> ...
%! ismember (days (1), days (ones (2, 3, 4)), 'rows')
%!error<duration.ismember: 'rows' requires same number of columns.> ...
%! ismember (days (1), days (ones (2, 3)), 'rows')
%!error<duration.ismember: all options must be character vectors.> ...
%! ismember (days (1), days (1), 3)
%!error<duration.ismember: only 'rows' and 'legacy' are valid options.> ...
%! ismember (days (1), days (1), 'row')

%!assert (ismissing (days ([1, 2, 3, NaN, 5])), logical ([0, 0, 0, 1, 0]))
%!assert (ismissing (days ([1, 2, 3, NaN, 5]), days (1)), logical ([1, 0, 0, 0, 0]))
%!assert (ismissing (days ([1, 2, 3, NaN, 5]), duration (24, 0, 0)), logical ([1, 0, 0, 0, 0]))
%!assert (ismissing (days ([1, 2, 3, NaN, 5]), duration ('48:00:00')), logical ([0, 1, 0, 0, 0]))
%!assert (ismissing (seconds ([1:5]), duration (0, 0, [1:3])), logical ([1, 1, 1, 0, 0]))
%!assert (ismissing (days ([1, 2, 3, NaN, 5]), days ([1, 3])), logical ([1, 0, 1, 0, 0]))
%!assert (ismissing (days ([1, 2, 3, NaN, 5]), days ([1, 6])), logical ([1, 0, 0, 0, 0]))
%!assert (ismissing (days ([1, 2, 3, NaN, 5]), days ([1, 5, 6])), logical ([1, 0, 0, 0, 1]))
%!error<duration.ismissing: too many input arguments.> ...
%! ismissing (days (1), days (1), days (1))
%!error<duration.ismissing: INDICATOR must be a 'duration' array.> ...
%! ismissing (days ([1, 2, 3, NaN, 5]), 5)
%!error<duration.ismissing: INDICATOR must be a 'duration' array.> ...
%! ismissing (days ([1, 2, 3, NaN, 5]), '24:00:00')
%!error<duration.ismissing: INDICATOR must be a 'duration' array.> ...
%! ismissing (days ([1, 2, 3, NaN, 5]), string ('24:00:00'))

%!assert (isnan (minutes ([1:10])), false (1, 10))
%!assert (isnan (days ([1, 2, NaN, 4, NaN])), logical ([0, 0, 1, 0, 1]))
%!assert (isnan (duration (NaN (3, 4, 5), 0, 0)), true (3, 4, 5))
%!assert (isnan (duration (zeros (3, 4, 5), 0, 0)), false (3, 4, 5))

%!assert (isrow (days ([1, 2, 3, 4])), true)
%!assert (isrow (days ([1; 2; 3; 4])), false)
%!assert (isrow (days ([1, 2; 3, 4])), false)
%!assert (isrow (days ([])), false)
%!assert (isrow (days (ones (1, 0))), true)
%!assert (isrow (days (ones (0, 1))), false)
%!assert (isrow (days (1)), true)
%!assert (isrow (days (ones (2, 3, 4))), false)

%!assert (isscalar (days ([])), false)
%!assert (isscalar (days (ones (1, 0))), false)
%!assert (isscalar (days (ones (0, 1))), false)
%!assert (isscalar (days (1)), true)
%!assert (isscalar (days (NaN)), true)
%!assert (isscalar (days ([1, 2])), false)

%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! assert (issorted (sort (D)), true);
%! assert (issorted (sort (D), 'ascend'), true);
%! assert (issorted (sort (D), 'descend'), false);
%! assert (issorted (sort (D), 'monotonic'), true);
%! assert (issorted (sort (D), 'strictascend'), false);
%! assert (issorted (sort (D), 'strictdescend'), false);
%! assert (issorted (sort (D), 'strictmonotonic'), false);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! assert (issorted (sort (D, 2), 2), true);
%! assert (issorted (sort (D, 2), 2, 'ascend'), true);
%! assert (issorted (sort (D, 2), 2, 'descend'), false);
%! assert (issorted (sort (D, 2), 2, 'monotonic'), true);
%! assert (issorted (sort (D, 2), 2, 'strictascend'), true);
%! assert (issorted (sort (D, 2), 2, 'strictdescend'), false);
%! assert (issorted (sort (D, 2), 2, 'strictmonotonic'), true);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! assert (issorted (sort (D, 2), 'ascend'), false);
%! assert (issorted (sort (D, 2), 'descend'), false);
%! assert (issorted (sort (D, 2), 'monotonic'), false);
%! assert (issorted (sort (D, 2), 'strictascend'), false);
%! assert (issorted (sort (D, 2), 'strictdescend'), false);
%! assert (issorted (sort (D, 2), 'strictmonotonic'), false);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! assert (issorted (sort (D, 'descend'), 'ascend'), false);
%! assert (issorted (sort (D, 'descend'), 'descend'), true);
%! assert (issorted (sort (D, 'descend'), 'monotonic'), true);
%! assert (issorted (sort (D, 'descend'), 'strictascend'), false);
%! assert (issorted (sort (D, 'descend'), 'strictdescend'), false);
%! assert (issorted (sort (D, 'descend'), 'strictmonotonic'), false);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! assert (issorted (sort (D, 2, 'descend'), 2, 'ascend'), false);
%! assert (issorted (sort (D, 2, 'descend'), 2, 'descend'), true);
%! assert (issorted (sort (D, 2, 'descend'), 2, 'monotonic'), true);
%! assert (issorted (sort (D, 2, 'descend'), 2, 'strictascend'), false);
%! assert (issorted (sort (D, 2, 'descend'), 2, 'strictdescend'), true);
%! assert (issorted (sort (D, 2, 'descend'), 2, 'strictmonotonic'), true);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! assert (issorted (sort (D, 2, 'descend'), 'ascend'), false);
%! assert (issorted (sort (D, 2, 'descend'), 'descend'), false);
%! assert (issorted (sort (D, 2, 'descend'), 'monotonic'), false);
%! assert (issorted (sort (D, 2, 'descend'), 'strictascend'), false);
%! assert (issorted (sort (D, 2, 'descend'), 'strictdescend'), false);
%! assert (issorted (sort (D, 2, 'descend'), 'strictmonotonic'), false);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! assert (issorted (sort (D, 'ComparisonMethod', 'real')), true);
%! assert (issorted (sort (D, 'ComparisonMethod', 'abs')), false);
%! assert (issorted (sort (D, 'ComparisonMethod', 'abs'), ...
%!                   'ComparisonMethod', 'abs'), true);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! assert (issorted (sort (D, 2, 'ComparisonMethod', 'real'), 2), true);
%! assert (issorted (sort (D, 2, 'ComparisonMethod', 'abs'), 2), false);
%! assert (issorted (sort (D, 2, 'ComparisonMethod', 'abs'), 2, ...
%!                   'ComparisonMethod', 'abs'), true);
%!test
%! D = days ([1, 2; 2, 3; 3, 4; 4, 5]);
%! assert (issorted (sort (D), 'ascend'), true);
%! assert (issorted (sort (D), 'descend'), false);
%! assert (issorted (sort (D), 'monotonic'), true);
%! assert (issorted (sort (D), 'strictascend'), true);
%! assert (issorted (sort (D), 'strictdescend'), false);
%! assert (issorted (sort (D), 'strictmonotonic'), true);
%!test
%! D = days ([1, 2; 2, 3; 3, 4; 4, 5]);
%! assert (issorted (sort (D, 'descend'), 'ascend'), false);
%! assert (issorted (sort (D, 'descend'), 'descend'), true);
%! assert (issorted (sort (D, 'descend'), 'monotonic'), true);
%! assert (issorted (sort (D, 'descend'), 'strictascend'), false);
%! assert (issorted (sort (D, 'descend'), 'strictdescend'), true);
%! assert (issorted (sort (D, 'descend'), 'strictmonotonic'), true);
%!test
%! D = days ([1, 2; 2, 3; 3, 4; 4, NaN]);
%! assert (issorted (sort (D)), true);
%! assert (issorted (sort (D), 'ascend'), true);
%! assert (issorted (sort (D), 'descend'), false);
%! assert (issorted (sort (D), 'monotonic'), true);
%! assert (issorted (sort (D), 'strictascend'), false);
%! assert (issorted (sort (D), 'strictdescend'), false);
%! assert (issorted (sort (D), 'strictmonotonic'), false);
%!test
%! D = days ([1, 2; 2, 3; 3, 4; 4, NaN]);
%! assert (issorted (sort (D, 'descend'), 'ascend'), false);
%! assert (issorted (sort (D, 'descend'), 'descend'), true);
%! assert (issorted (sort (D, 'descend'), 'monotonic'), true);
%! assert (issorted (sort (D, 'descend'), 'strictascend'), false);
%! assert (issorted (sort (D, 'descend'), 'strictdescend'), false);
%! assert (issorted (sort (D, 'descend'), 'strictmonotonic'), false);
%!test
%! D = days ([1, 2; 2, 3; 3, 4; 4, NaN]);
%! assert (issorted (sort (D, 'MissingPlacement', 'auto')), true);
%! assert (issorted (sort (D, 'MissingPlacement', 'first')), false);
%! assert (issorted (sort (D, 'MissingPlacement', 'first'), ...
%!                   'MissingPlacement', 'first'), true);
%!test
%! D = days ([1, 2; 2, 3; 3, 4; 4, NaN]);
%! assert (issorted (sort (D, 'descend', 'MissingPlacement', 'auto'), 'descend'), true);
%! assert (issorted (sort (D, 'descend', 'MissingPlacement', 'last'), 'descend'), false);
%! assert (issorted (sort (D, 'descend', 'MissingPlacement', 'first'), ...
%!                   'descend', 'MissingPlacement', 'first'), true);
%!test
%! D = days ([1, 2; 2, 3; 3, 4; 4, NaN]);
%! assert (issorted (sort (D, 2, 'MissingPlacement', 'auto'), 2), true);
%! assert (issorted (sort (D, 2, 'MissingPlacement', 'first'), 2), false);
%! assert (issorted (sort (D, 2, 'MissingPlacement', 'first'), 2, ...
%!                   'MissingPlacement', 'first'), true);
%!test
%! D = days ([1, 2; 2, 3; 3, 4; 4, NaN]);
%! assert (issorted (sort (D, 2, 'descend', 'MissingPlacement', 'auto'), 2, 'descend'), true);
%! assert (issorted (sort (D, 2, 'descend', 'MissingPlacement', 'last'), 2, 'descend'), false);
%! assert (issorted (sort (D, 2, 'descend', 'MissingPlacement', 'first'), 2, ...
%!                   'descend', 'MissingPlacement', 'first'), true);
%!test
%! D = days ([1, 2; 2, 3; 3, 4; 4, NaN]);
%! assert (issorted (sort (D, 2, string ('ascend'), 'MissingPlacement', 'auto'), 2), true);
%! assert (issorted (sort (D, 2, string ('ascend'), 'MissingPlacement', 'first'), 2), false);
%! assert (issorted (sort (D, 2, string ('ascend'), 'MissingPlacement', 'first'), 2, ...
%!                   'MissingPlacement', 'first'), true);
%!test
%! D = days ([1, 2; 2, 3; 3, 4; 4, NaN]);
%! assert (issorted (sort (D, 2, string ('descend'), 'MissingPlacement', 'auto'), 2, 'descend'), true);
%! assert (issorted (sort (D, 2, string ('descend'), 'MissingPlacement', 'last'), 2, 'descend'), false);
%! assert (issorted (sort (D, 2, string ('descend'), 'MissingPlacement', 'first'), 2, ...
%!                   'descend', 'MissingPlacement', 'first'), true);
%!test
%! D = days ([1, 2; 2, -3; 3, 4; 4, NaN]);
%! assert (issorted (sort (D, 'MissingPlacement', 'auto', ...
%!                         'ComparisonMethod', 'real')), true);
%! assert (issorted (sort (D, 'MissingPlacement', 'auto', ...
%!                         'ComparisonMethod', 'abs')), false);
%! assert (issorted (sort (D, 'MissingPlacement', 'auto', ...
%!                         'ComparisonMethod', 'abs'), 'ComparisonMethod', 'abs'), true);
%! assert (issorted (sort (D, 'MissingPlacement', 'last', ...
%!                         'ComparisonMethod', 'abs')), false);
%! assert (issorted (sort (D, 'MissingPlacement', 'last', ...
%!                         'ComparisonMethod', 'abs'), 'ComparisonMethod', 'abs'), true);
%! assert (issorted (sort (D, 'MissingPlacement', 'first', ...
%!                         'ComparisonMethod', 'abs'), ...
%!                   'MissingPlacement', 'first', 'ComparisonMethod', 'abs'), true);
%!test
%! D = days ([1, 2; 2, -3; 3, 4; 4, NaN]);
%! assert (issorted (sort (D, 'descend', 'MissingPlacement', 'auto', ...
%!                         'ComparisonMethod', 'real'), 'descend'), true);
%! assert (issorted (sort (D, 'descend', 'MissingPlacement', 'auto', ...
%!                         'ComparisonMethod', 'abs'), 'descend'), false);
%! assert (issorted (sort (D, 'descend', 'MissingPlacement', 'auto', ...
%!                         'ComparisonMethod', 'abs'), ...
%!                   'descend', 'ComparisonMethod', 'abs'), true);
%! assert (issorted (sort (D, 'descend', 'MissingPlacement', 'last', ...
%!                         'ComparisonMethod', 'abs'), 'descend'), false);
%! assert (issorted (sort (D, 'descend', 'MissingPlacement', 'last', ...
%!                         'ComparisonMethod', 'abs'), ...
%!                   'descend', 'ComparisonMethod', 'abs'), false);
%! assert (issorted (sort (D, 'descend', 'MissingPlacement', 'first', ...
%!                         'ComparisonMethod', 'abs'), 'descend'), false);
%! assert (issorted (sort (D, 'descend', 'MissingPlacement', 'first', ...
%!                         'ComparisonMethod', 'abs'), ...
%!                   'descend', 'ComparisonMethod', 'abs'), true);
%! assert (issorted (sort (D, 'descend', 'MissingPlacement', 'first', ...
%!                         'ComparisonMethod', 'abs'), 'descend', ...
%!                   'MissingPlacement', 'first', 'ComparisonMethod', 'abs'), true);

%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! assert (issortedrows (sortrows (D)), true);
%! assert (issortedrows (sortrows (D, 1)), true);
%! assert (issortedrows (sortrows (D, 1), -1), false);
%! assert (issortedrows (sortrows (D, 1), 1), true);
%! assert (issortedrows (sortrows (D, 2)), false);
%! assert (issortedrows (sortrows (D, 2), 2), true);
%! assert (issortedrows (sortrows (D, 2), -2), false);
%! assert (issortedrows (sortrows (D, -2), 2), false);
%! assert (issortedrows (sortrows (D, -2), -2), true);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! assert (issortedrows (sortrows (D, 'ComparisonMethod', 'abs')), false);
%! assert (issortedrows (sortrows (D, 'ComparisonMethod', 'real')), true);
%! assert (issortedrows (sortrows (D, 'ComparisonMethod', 'abs'), ...
%!                       'ComparisonMethod', 'abs'), true);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! assert (issortedrows (sortrows (D, 2, 'ComparisonMethod', 'abs'), 2), false);
%! assert (issortedrows (sortrows (D, 2, 'ComparisonMethod', 'real'), 2), true);
%! assert (issortedrows (sortrows (D, 2, 'ComparisonMethod', 'abs'), 2, ...
%!                       'ComparisonMethod', 'abs'), true);
%! assert (issortedrows (sortrows (D, [1, 2], 'ComparisonMethod', 'abs'), ...
%!                       {'ascend', 'ascend'}), false);
%! assert (issortedrows (sortrows (D, [1, 2], 'ComparisonMethod', 'abs'), ...
%!                       {'ascend', 'ascend'}, 'ComparisonMethod', 'abs'), true);
%! assert (issortedrows (sortrows (D, 2, 'ComparisonMethod', 'real'), 2), true);
%! assert (issortedrows (sortrows (D, [1, 2], 'ComparisonMethod', 'real'), ...
%!                       {'ascend', 'ascend'}, 'ComparisonMethod', 'auto'), true);
%! assert (issortedrows (sortrows (D, [-1, 2], 'ComparisonMethod', 'abs'), ...
%!                       {'ascend', 'ascend'}, 'ComparisonMethod', 'abs'), false);
%! assert (issortedrows (sortrows (D, 2, 'ComparisonMethod', 'real'), -2), false);
%! assert (issortedrows (sortrows (D, [1, 2], 'ComparisonMethod', 'real'), ...
%!                       {'ascend', 'descend'}, 'ComparisonMethod', 'auto'), false);
%! assert (issortedrows (sortrows (D, [1, -2], 'ComparisonMethod', 'real'), ...
%!                       {'ascend', 'descend'}, 'ComparisonMethod', 'auto'), true);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! assert (issortedrows (sortrows (D, [1, 2], 'ComparisonMethod', 'abs'), ...
%!                       [1, 2], string ({'ascend', 'ascend'})), false);
%! assert (issortedrows (sortrows (D, [1, 2], 'ComparisonMethod', 'abs'), ...
%!                       [1, 2], string ({'ascend', 'ascend'}), ...
%!                       'ComparisonMethod', 'abs'), true);
%! assert (issortedrows (sortrows (D, [1, 2], 'ComparisonMethod', 'abs'), ...
%!                       [1, -2], string ({'ascend', 'ascend'}), ...
%!                       'ComparisonMethod', 'abs'), true);
%! assert (issortedrows (sortrows (D, [1, 2], 'ComparisonMethod', 'real'), ...
%!                       [1, 2], string ({'ascend', 'ascend'}), ...
%!                       'ComparisonMethod', 'auto'), true);
%! assert (issortedrows (sortrows (D, [1, -2], string ({'ascend', 'ascend'}), ...
%!                                 'ComparisonMethod', 'real'), ...
%!                       [1, 2], string ({'ascend', 'ascend'}), ...
%!                       'ComparisonMethod', 'auto'), true);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! assert (issortedrows (sortrows (D)), true);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! assert (issortedrows (sortrows (D, -2, 'MissingPlacement', 'first')), false);
%! assert (issortedrows (sortrows (D, -2, 'MissingPlacement', 'first'), -2), true);
%! assert (issortedrows (sortrows (D, -2, 'MissingPlacement', 'last'), -2), false);
%! assert (issortedrows (sortrows (D, -2, 'MissingPlacement', 'last'), -2, ...
%!                       'MissingPlacement', 'last'), true);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! assert (issortedrows (sortrows (D, 2, 'MissingPlacement', 'last')), false);
%! assert (issortedrows (sortrows (D, 2, 'MissingPlacement', 'last'), 2), true);
%! assert (issortedrows (sortrows (D, 2, 'MissingPlacement', 'first'), 2), false);
%! assert (issortedrows (sortrows (D, 2, 'MissingPlacement', 'first'), 2, ...
%!                       'MissingPlacement', 'first'), true);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! assert (issortedrows (sortrows (D, 'ComparisonMethod', 'abs', ...
%!                                 'MissingPlacement', 'first'), ...
%!                       'ComparisonMethod', 'abs', ...
%!                       'MissingPlacement', 'first'), true);
%! assert (issortedrows (sortrows (D, 'ComparisonMethod', 'abs', ...
%!                                 'MissingPlacement', 'last'), ...
%!                       'ComparisonMethod', 'abs', ...
%!                       'MissingPlacement', 'first'), false);
%! assert (issortedrows (sortrows (D, 'ComparisonMethod', 'abs', ...
%!                                 'MissingPlacement', 'last'), ...
%!                       'ComparisonMethod', 'abs', ...
%!                       'MissingPlacement', 'auto'), true);
%! assert (issortedrows (sortrows (D, 'ComparisonMethod', 'abs', ...
%!                                 'MissingPlacement', 'last'), ...
%!                       'ComparisonMethod', 'abs'), true);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! assert (issortedrows (sortrows (D, [1, -2, 3]), [1, -2, 3]), true);
%! assert (issortedrows (sortrows (D, [1, 2, -3]), [1, -2, 3]), false);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! assert (issortedrows (sortrows (D, string ({'ascend', 'descend', 'ascend'})), ...
%!                       string ({'ascend', 'descend', 'ascend'})), true);
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! assert (issortedrows (sortrows (D, string ({'ascend', 'descend', 'ascend'})), ...
%!                       string ({'descend', 'ascend', 'ascend'})), false);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! assert (issortedrows (sortrows (D, [2, 3], string ({'descend', 'ascend'})), ...
%!                       [2, 3], string ({'descend', 'ascend'})), true);
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! assert (issortedrows (sortrows (D, [2, 3], string ({'ascend', 'descend'})), ...
%!                       [2, -3]), true);
%! assert (issortedrows (sortrows (D, [2, 3], string ({'descend', 'descend'})), ...
%!                       [2, -3], string ({'descend', 'ascend'})), false);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! assert (issortedrows (sortrows (D, [1, -2, 3], 'MissingPlacement', 'first'), ...
%!         [1, -2, 3], 'MissingPlacement', 'first'), true);
%! assert (issortedrows (sortrows (D, [-1, -2, -3], 'MissingPlacement', 'first'), ...
%!         [-1, -2, -3]), true);
%! assert (issortedrows (sortrows (D, [-1, -2, -3], 'MissingPlacement', 'first'), ...
%!         [1, -2,-3], string ({'descend', 'descend', 'descend'})), true);

%!assert (isvector (days ([1, 2, 3, 4])), true)
%!assert (isvector (days ([1; 2; 3; 4])), true)
%!assert (isvector (days ([1, 2; 3, 4])), false)
%!assert (isvector (days ([])), false)
%!assert (isvector (days (ones (1, 0))), true)
%!assert (isvector (days (ones (0, 1))), true)
%!assert (isvector (days (1)), true)
%!assert (isvector (days (ones (2, 3, 4))), false)

################################################################################
##                        ** Relational Operations **                         ##
################################################################################
##                             Available Methods                              ##
##                                                                            ##
## 'eq'               'ge'               'gt'               'le'              ##
## 'lt'               'ne'                                                    ##
##                                                                            ##
################################################################################

%!assert (duration (1, 0, 0) == '01:00:00', true)
%!assert (duration (1, 0, 0) == '01:00:01', false)
%!assert (duration (1, 0, 0) == {'01:00:00'}, true)
%!assert (duration (1, 0, 1) == {'01:00:00'}, false)
%!assert (duration (1, 0, 0) == string ('01:00:00'), true)
%!assert (duration (NaN, 0, 0) == string ('01:00:00'), false)
%!assert (duration (24, 0, 0) == 1, true)
%!assert (duration (NaN, 0, 0) == NaN, false)
%!assert (duration (24, 0, 0) == days (1), true)
%!assert ('01:00:00' == duration (1, 0, 0), true)
%!assert ({'01:00:00'} == duration (1, 0, 0), true)
%!assert (string ('01:00:00') == duration (1, 0, 0), true)
%!assert (1 == duration (24, 0, 0), true)
%!assert (days (1) == duration (24, 0, 0), true)
%!assert (days (NaN) == duration (NaN, 0, 0), false)
%!assert (duration (1, 0, 0) == hours (1), true)
%!assert (duration (0, 1, 0) == minutes (1), true)
%!assert (duration (0, 0, 1) == seconds (1), true)
%!assert (days ([1, 2]) == 1, [true, false])
%!assert (days ([1; 2]) == 1, [true; false])
%!assert (days ([1, 2]) == [1, 2], [true, true])
%!assert (days ([1, 2]) == [1; 2], logical (eye (2)))

%!assert (duration (1, 0, 0) >= '01:00:00', true)
%!assert (duration (1, 0, 0) >= '01:00:01', false)
%!assert (duration (1, 0, 0) >= {'01:00:00'}, true)
%!assert (duration (1, 0, 1) >= {'01:00:00'}, true)
%!assert (duration (1, 0, 0) >= string ('01:00:00'), true)
%!assert (duration (NaN, 0, 0) >= string ('01:00:00'), false)
%!assert (duration (24, 0, 0) >= 1, true)
%!assert (duration (NaN, 0, 0) >= NaN, false)
%!assert (duration (24, 0, 0) >= days (1), true)
%!assert ('01:00:00' >= duration (1, 0, 0), true)
%!assert ('01:00:00' >= duration (1, 0, 1), false)
%!assert ({'01:00:00'} >= duration (1, 0, 0), true)
%!assert (string ('01:00:00') >= duration (1, 0, 0), true)
%!assert (string ('01:00:01') >= duration (1, 0, 0), true)
%!assert (string ('01:00:00') >= duration (1, 1, 0), false)
%!assert (1 >= duration (24, 0, 0), true)
%!assert (days (1) >= duration (24, 0, 0), true)
%!assert (days (NaN) >= duration (NaN, 0, 0), false)
%!assert (duration (1, 0, 0) >= hours (1), true)
%!assert (duration (0, 1, 0) >= minutes (1), true)
%!assert (duration (0, 0, 1) >= seconds (1), true)
%!assert (days ([1, 2]) >= 1, [true, true])
%!assert (days ([1; 2]) >= 1, [true; true])
%!assert (days ([1, 2]) >= [1, 2], [true, true])
%!assert (days ([1, 2]) >= [1; 2], [true, true; false, true])

%!assert (duration (1, 0, 0) > '01:00:00', false)
%!assert (duration (1, 0, 0) > '01:00:01', false)
%!assert (duration (1, 0, 0) > {'01:00:00'}, false)
%!assert (duration (1, 0, 1) > {'01:00:00'}, true)
%!assert (duration (1, 0, 0) > string ('01:00:00'), false)
%!assert (duration (NaN, 0, 0) > string ('01:00:00'), false)
%!assert (duration (24, 0, 0) > 1, false)
%!assert (duration (NaN, 0, 0) > NaN, false)
%!assert (duration (24, 0, 0) > days (1), false)
%!assert (duration (24, 0, 1) > days (1), true)
%!assert ('01:00:00' > duration (1, 0, 0), false)
%!assert ('01:00:01' > duration (1, 0, 0), true)
%!assert ('01:00:00' > duration (1, 0, 1), false)
%!assert ({'01:00:00'} > duration (1, 0, 0), false)
%!assert (string ('01:00:00') > duration (1, 0, 0), false)
%!assert (string ('01:00:01') > duration (1, 0, 0), true)
%!assert (string ('01:00:00') > duration (1, 1, 0), false)
%!assert (1 > duration (24, 0, 0), false)
%!assert (days (1) > duration (24, 0, 0), false)
%!assert (days (1.05) > duration (24, 0, 0), true)
%!assert (days (NaN) > duration (NaN, 0, 0), false)
%!assert (duration (1, 0, 0) > hours (1), false)
%!assert (duration (0, 1, 0) > minutes (1), false)
%!assert (duration (0, 0, 1) > seconds (1), false)
%!assert (days ([1, 2]) > 1, [false, true])
%!assert (days ([1; 2]) > 1, [false; true])
%!assert (days ([1, 2]) > [1, 2], [false, false])
%!assert (days ([1, 2]) > [1; 2], [false, true; false, false])

%!assert (duration (1, 0, 0) <= '01:00:00', true)
%!assert (duration (1, 0, 0) <= '01:00:01', true)
%!assert (duration (1, 0, 0) <= {'01:00:00'}, true)
%!assert (duration (1, 0, 1) <= {'01:00:00'}, false)
%!assert (duration (1, 0, 0) <= string ('01:00:00'), true)
%!assert (duration (NaN, 0, 0) <= string ('01:00:00'), false)
%!assert (duration (24, 0, 0) <= 1, true)
%!assert (duration (NaN, 0, 0) <= NaN, false)
%!assert (duration (24, 0, 0) <= days (1), true)
%!assert ('01:00:00' <= duration (1, 0, 0), true)
%!assert ('01:00:00' <= duration (1, 0, 1), true)
%!assert ({'01:00:00'} <= duration (1, 0, 0), true)
%!assert (string ('01:00:00') <= duration (1, 0, 0), true)
%!assert (string ('01:00:01') <= duration (1, 0, 0), false)
%!assert (string ('01:00:00') <= duration (1, 1, 0), true)
%!assert (1 <= duration (24, 0, 0), true)
%!assert (days (1) <= duration (24, 0, 0), true)
%!assert (days (NaN) <= duration (NaN, 0, 0), false)
%!assert (duration (1, 0, 0) <= hours (1), true)
%!assert (duration (0, 1, 0) <= minutes (1), true)
%!assert (duration (0, 0, 1) <= seconds (1), true)
%!assert (days ([1, 2]) <= 1, [true, false])
%!assert (days ([1; 2]) <= 1, [true; false])
%!assert (days ([1, 2]) <= [1, 2], [true, true])
%!assert (days ([1, 2]) <= [1; 2], [true, false; true, true])

%!assert (duration (1, 0, 0) < '01:00:00', false)
%!assert (duration (1, 0, 0) < '01:00:01', true)
%!assert (duration (1, 0, 0) < {'01:00:00'}, false)
%!assert (duration (1, 0, 1) < {'01:00:00'}, false)
%!assert (duration (1, 0, 0) < string ('01:00:00'), false)
%!assert (duration (NaN, 0, 0) < string ('01:00:00'), false)
%!assert (duration (24, 0, 0) < 1, false)
%!assert (duration (NaN, 0, 0) < NaN, false)
%!assert (duration (24, 0, 0) < days (1), false)
%!assert (duration (24, 0, 1) < days (1), false)
%!assert ('01:00:00' < duration (1, 0, 0), false)
%!assert ('01:00:01' < duration (1, 0, 0), false)
%!assert ('01:00:00' < duration (1, 0, 1), true)
%!assert ({'01:00:00'} < duration (1, 0, 0), false)
%!assert (string ('01:00:00') < duration (1, 0, 0), false)
%!assert (string ('01:00:01') < duration (1, 0, 0), false)
%!assert (string ('01:00:00') < duration (1, 1, 0), true)
%!assert (1 < duration (24, 0, 0), false)
%!assert (days (1) < duration (24, 0, 0), false)
%!assert (days (1.05) < duration (24, 0, 0), false)
%!assert (days (NaN) < duration (NaN, 0, 0), false)
%!assert (duration (1, 0, 0) < hours (1), false)
%!assert (duration (0, 1, 0) < minutes (1), false)
%!assert (duration (0, 0, 1) < seconds (1), false)
%!assert (days ([1, 2]) < 1, [false, false])
%!assert (days ([1; 2]) < 1, [false; false])
%!assert (days ([1, 2]) < [1, 2], [false, false])
%!assert (days ([1, 2]) < [1; 2], [false, false; true, false])

%!assert (duration (1, 0, 0) != '01:00:00', false)
%!assert (duration (1, 0, 0) != '01:00:01', true)
%!assert (duration (1, 0, 0) != {'01:00:00'}, false)
%!assert (duration (1, 0, 1) != {'01:00:00'}, true)
%!assert (duration (1, 0, 0) != string ('01:00:00'), false)
%!assert (duration (NaN, 0, 0) != string ('01:00:00'), true)
%!assert (duration (24, 0, 0) != 1, false)
%!assert (duration (NaN, 0, 0) != NaN, true)
%!assert (duration (24, 0, 0) != days (1), false)
%!assert ('01:00:00' != duration (1, 0, 0), false)
%!assert ({'01:00:00'} != duration (1, 0, 0), false)
%!assert (string ('01:00:00') != duration (1, 0, 0), false)
%!assert (1 != duration (24, 0, 0), false)
%!assert (days (1) != duration (24, 0, 0), false)
%!assert (days (NaN) != duration (NaN, 0, 0), true)
%!assert (duration (1, 0, 0) != hours (1), false)
%!assert (duration (0, 1, 0) != minutes (1), false)
%!assert (duration (0, 0, 1) != seconds (1), false)
%!assert (days ([1, 2]) != 1, [false, true])
%!assert (days ([1; 2]) != 1, [false; true])
%!assert (days ([1, 2]) != [1, 2], [false, false])
%!assert (days ([1, 2]) != [1; 2], [false, true; true, false])

################################################################################
##                       ** Mathematical Operations **                        ##
################################################################################
##                             Available Methods                              ##
##                                                                            ##
## 'abs'              'plus'             'uplus'            'minus'           ##
## 'uminus'           'times'            'mtimes'           'ldivide'         ##
## 'rdivide'          'colon'            'linspace'         'sign'            ##
## 'sum'              'cumsum'           'diff'             'min'             ##
## 'max'              'cummin'           'cummax'           'floor'           ##
## 'ceil'             'round'                                                 ##
##                                                                            ##
################################################################################

%!assert (days (abs (days ([1, -1, NaN, -Inf, Inf]))), [1, 1, NaN, Inf, Inf])
%!assert (days (abs (days (- ones (2, 3, 4)))), ones (2, 3, 4))

%!assert (days (days ([1, 2; NaN, Inf]) + [2, 3]), [3, 5; NaN, Inf])
%!assert (days (days ([1, 2; NaN, Inf]) + days ([2, 3])), [3, 5; NaN, Inf])
%!assert (days ([2, 3] + days ([1, 2; NaN, Inf])), [3, 5; NaN, Inf])
%!assert (days (days ([2, 3]) + days ([1, 2; NaN, Inf])), [3, 5; NaN, Inf])
%!assert (caldays (days (1) + calendarDuration), 0)
%!assert (caldays (days (1) + calendarDuration (0, 0, 1)), 1)
%!assert (hours (time (days (1) + calendarDuration)), 24)
%!assert (hours (time (days (1) + calendarDuration (0, 0, 1))), 24)
%!assert (class (days (1) + calendarDuration), 'calendarDuration')
%!error<duration: addition is not defined between 'duration' and 'char' arrays.> ...
%! days (1) + '24:00:00'
%!error<duration: addition is not defined between 'duration' and 'cell' arrays.> ...
%! days (1) + {'24:00:00'}
%!error<duration: addition is not defined between 'duration' and 'string' arrays.> ...
%! days (1) + string('24:00:00')

%!assert (days (+ days (-3)), -3)
%!assert (days (+ days (magic (3))), magic (3))

%!assert (days (days ([3, 5; NaN, Inf]) - [2, 3]), [1, 2; NaN, Inf])
%!assert (days (days ([3, 5; NaN, Inf]) - days ([2, 3])), [1, 2; NaN, Inf])
%!assert (days ([3, 5] - days ([2, 3; NaN, Inf])), [1, 2; NaN, -Inf])
%!assert (days (days ([3, 5]) - days ([2, 3; NaN, Inf])), [1, 2; NaN, -Inf])
%!assert (caldays (days (1) - calendarDuration), 0)
%!assert (caldays (days (1) - calendarDuration (0, 0, 1)), -1)
%!assert (hours (time (days (1) - calendarDuration)), 24)
%!assert (hours (time (days (1) - calendarDuration (0, 0, 1))), 24)
%!assert (class (days (1) - calendarDuration), 'calendarDuration')
%!error<duration: subtraction is not defined between 'duration' and 'char' arrays.> ...
%! days (1) - '24:00:00'
%!error<duration: subtraction is not defined between 'duration' and 'cell' arrays.> ...
%! days (1) - {'24:00:00'}
%!error<duration: subtraction is not defined between 'duration' and 'string' arrays.> ...
%! days (1) - string('24:00:00')

%!assert (days (- days (-3)), 3)
%!assert (days (- days (3)), -3)
%!assert (days (- days (magic (3))), - magic (3))

%!assert (days (days ([1:3]) .* [1:3]), [1, 4, 9])
%!assert (days ([1:3] .* days ([1:3])), [1, 4, 9])
%!assert (days (days ([1:3]) .* [1; 2]), [1, 2, 3; 2, 4, 6])
%!assert (days ([1; 2] .* days ([1:3])), [1, 2, 3; 2, 4, 6])
%!assert (class (1 .* duration), 'duration')
%!assert (class (duration .* magic (3)), 'duration')
%!assert (hours (duration .* magic (3)), zeros (3))
%!error<duration: multiplication is not defined between 'duration' and 'duration' arrays.> ...
%! days (1) .* days (1)
%!error<duration: multiplication is not defined between 'duration' and 'char' arrays.> ...
%! days (1) .* 'asd'
%!error<duration: multiplication is not defined between 'duration' and 'string' arrays.> ...
%! days (1) .* string ({'asd'})
%!error<duration: multiplication is not defined between 'cell' and 'duration' arrays.> ...
%! {'asd'} .*  days (1)

%!assert (days (days ([1:3]) * [1:3]'), 14)
%!assert (days (days ([1:3]') * [1:3]), [1, 2, 3; 2, 4, 6; 3, 6, 9])
%!assert (days ([1:3] * days ([1:3]')), 14)
%!assert (days ([1:3]' * days ([1:3])), [1, 2, 3; 2, 4, 6; 3, 6, 9])
%!assert (class (1 * duration), 'duration')
%!assert (class (days (magic (3)) * magic (3)), 'duration')
%!assert (days (days (magic (3)) * magic (3)), magic (3) * magic (3))
%!assert (days (magic (3) * days (magic (3))), magic (3) * magic (3))
%!error<duration: matrix multiplication is not defined between 'duration' and 'duration' arrays.> ...
%! days (1) * days (1)
%!error<duration: matrix multiplication is not defined between 'duration' and 'char' arrays.> ...
%! days (1) * 'asd'
%!error<duration: matrix multiplication is not defined between 'duration' and 'string' arrays.> ...
%! days (1) * string ({'asd'})
%!error<duration: matrix multiplication is not defined between 'cell' and 'duration' arrays.> ...
%! {'asd'} *  days (1)

%!assert (days ([1:3]) .\ days ([1:3]), [1, 1, 1])
%!assert (days ([1:3] .\ days ([1:3])), [1, 1, 1])
%!assert (days ([1; 2] .\ days ([1:3])), [1, 2, 3; 0.5, 1, 1.5])
%!assert (class (1 .\ duration), 'duration')
%!assert (class (duration .\ duration), 'double')
%!error<duration: right-hand side must be a duration array for left division: got 'double'> ...
%! days (1) .\ 1
%!error<duration: left division is not defined between 'char' and 'duration' arrays.> ...
%! 'asd' .\ days (1)

%!assert (days ([1:3]) ./ days ([1:3]), [1, 1, 1])
%!assert (days (days ([1:3]) ./ [1:3]), [1, 1, 1])
%!assert (days (days ([1; 2]) ./ [1:3]), [1, 0.5, 1/3; 2, 1, 2/3])
%!assert (class (duration ./ 1), 'duration')
%!assert (class (duration ./ duration), 'double')
%!error<duration: left-hand side must be a duration array for right division: got 'double'> ...
%! 1 ./ days (1)
%!error<duration: right division is not defined between 'duration' and 'char' arrays.> ...
%! days (1) ./ 'asd'

################################################################################
##                   ** Sort, Filter, and Set Operations **                   ##
################################################################################
##                             Available Methods                              ##
##                                                                            ##
## 'sort'             'sortrows'         'unique'           'interp1'         ##
## 'intersect'        'setdiff'          'setxor'           'union'           ##
##                                                                            ##
################################################################################

%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sort (D);
%! assert (days (D), [1, -4; 1, 1; 2, 2; 2, 3]);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sort (D, 1);
%! assert (days (D), [1, -4; 1, 1; 2, 2; 2, 3]);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sort (D, 2);
%! assert (days (D), [1, 2; 1, 3; -4, 2; 1, 2]);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sort (D, 1, 'ComparisonMethod', 'abs');
%! assert (days (D), [1, 1; 1, 2; 2, 3; 2, -4]);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sort (D, 2, 'ComparisonMethod', 'abs');
%! assert (days (D), [1, 2; 1, 3; 2, -4; 1, 2]);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sort (D, 'descend');
%! assert (days (D), [2, 3; 2, 2; 1, 1; 1, -4]);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sort (D, 1, 'descend');
%! assert (days (D), [2, 3; 2, 2; 1, 1; 1, -4]);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sort (D, 2, 'descend');
%! assert (days (D), [2, 1; 3, 1; 2, -4; 2, 1]);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sort (D, 1, 'descend', 'ComparisonMethod', 'abs');
%! assert (days (D), [2, -4; 2, 3; 1, 2; 1, 1]);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sort (D, 2, 'descend', 'ComparisonMethod', 'abs');
%! assert (days (D), [2, 1; 3, 1; -4, 2; 2, 1]);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D);
%! X = [-2, -4, 1; 1, 1, 2; 1, 2, 2; 1, 3, 2; 2, 3, 3; 2, NaN, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 1);
%! X = [-2, -4, 1; 1, 1, 2; 1, 2, 2; 1, 3, 2; 2, 3, 3; 2, NaN, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 2);
%! X = [1, 2, 2; 1, 1, 3; -4, 2, 2; 1, 2, NaN; -2, 3, NaN; 1, 2, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 1, 'ComparisonMethod', 'abs');
%! X = [1, 1, 1; 1, 2, 2; 1, 3, 2; 2, 3, 2; 2, -4, 3; -2, NaN, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 2, 'ComparisonMethod', 'abs');
%! X = [1, 2, 2; 1, 1, 3; 2, 2, -4; 1, 2, NaN; -2, 3, NaN; 1, 2, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 1, 'MissingPlacement', 'first');
%! X = [-2, NaN, NaN; 1, -4, 1; 1, 1, 2; 1, 2, 2; 2, 3, 2; 2, 3, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 2, 'MissingPlacement', 'first');
%! X = [1, 2, 2; 1, 1, 3; -4, 2, 2; NaN, 1, 2; NaN, -2, 3; 1, 2, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 1, 'MissingPlacement', 'last');
%! X = [-2, -4, 1; 1, 1, 2; 1, 2, 2; 1, 3, 2; 2, 3, 3; 2, NaN, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 2, 'MissingPlacement', 'last');
%! X = [1, 2, 2; 1, 1, 3; -4, 2, 2; 1, 2, NaN; -2, 3, NaN; 1, 2, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 'descend');
%! X = [2, NaN, NaN; 2, 3, 3; 1, 3, 2; 1, 2, 2; 1, 1, 2; -2, -4, 1];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 1, 'descend');
%! X = [2, NaN, NaN; 2, 3, 3; 1, 3, 2; 1, 2, 2; 1, 1, 2; -2, -4, 1];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 2, 'descend');
%! X = [2, 2, 1; 3, 1, 1; 2, 2, -4; NaN, 2, 1; NaN, 3, -2; 3, 2, 1];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 1, 'descend', 'ComparisonMethod', 'abs');
%! X = [2, NaN, NaN; 2, -4, 3; -2, 3, 2; 1, 3, 2; 1, 2, 2; 1, 1, 1];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 2, 'descend', 'ComparisonMethod', 'abs');
%! X = [2, 2, 1; 3, 1, 1; -4, 2, 2; NaN, 2, 1; NaN, 3, -2; 3, 2, 1];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 1, 'descend', 'MissingPlacement', 'first');
%! X = [2, NaN, NaN; 2, 3, 3; 1, 3, 2; 1, 2, 2; 1, 1, 2; -2, -4, 1];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 2, 'descend', 'MissingPlacement', 'first');
%! X = [2, 2, 1; 3, 1, 1; 2, 2, -4; NaN, 2, 1; NaN, 3, -2; 3, 2, 1];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 1, 'descend', 'MissingPlacement', 'last');
%! X = [2, 3, 3; 2, 3, 2; 1, 2, 2; 1, 1, 2; 1, -4, 1; -2, NaN, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 2, 'descend', 'MissingPlacement', 'last');
%! X = [2, 2, 1; 3, 1, 1; 2, 2, -4; 2, 1, NaN; 3, -2, NaN; 3, 2, 1];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 1, 'MissingPlacement', 'first', 'ComparisonMethod', 'abs');
%! X = [1, NaN, NaN; 1, 1, 1; 1, 2, 2; 2, 3, 2; 2, 3, 2; -2, -4, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 2, 'MissingPlacement', 'first', 'ComparisonMethod', 'abs');
%! X = [1, 2, 2; 1, 1, 3; 2, 2, -4; NaN, 1, 2; NaN, -2, 3; 1, 2, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 1, 'MissingPlacement', 'last', 'ComparisonMethod', 'abs');
%! X = [1, 1, 1; 1, 2, 2; 1, 3, 2; 2, 3, 2; 2, -4, 3; -2, NaN, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 2, 'MissingPlacement', 'last', 'ComparisonMethod', 'abs');
%! X = [1, 2, 2; 1, 1, 3; 2, 2, -4; 1, 2, NaN; -2, 3, NaN; 1, 2, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 1, 'descend', 'MissingPlacement', 'first', 'ComparisonMethod', 'abs');
%! X = [2, NaN, NaN; 2, -4, 3; -2, 3, 2; 1, 3, 2; 1, 2, 2; 1, 1, 1];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 2, 'descend', 'MissingPlacement', 'first', 'ComparisonMethod', 'abs');
%! X = [2, 2, 1; 3, 1, 1; -4, 2, 2; NaN, 2, 1; NaN, 3, -2; 3, 2, 1];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 1, 'descend', 'MissingPlacement', 'last', 'ComparisonMethod', 'abs');
%! X = [2, -4, 3; 2, 3, 2; -2, 3, 2; 1, 2, 2; 1, 1, 1; 1, NaN, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sort (D, 2, 'descend', 'MissingPlacement', 'last', 'ComparisonMethod', 'abs');
%! X = [2, 2, 1; 3, 1, 1; -4, 2, 2; 2, 1, NaN; 3, -2, NaN; 3, 2, 1];
%! assert (days (D), X);

%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sortrows (D);
%! assert (days (D), [1, 2; 1, 3; 2, -4; 2, 1]);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sortrows (D, 'ComparisonMethod', 'abs');
%! assert (days (D), [1, 2; 1, 3; 2, 1; 2, -4]);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sortrows (D, 1, 'ComparisonMethod', 'abs');
%! assert (days (D), [1, 2; 1, 3; 2, -4; 2, 1]);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sortrows (D, 2, 'ComparisonMethod', 'abs');
%! assert (days (D), [2, 1; 1, 2; 1, 3; 2, -4]);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sortrows (D, -1, 'ComparisonMethod', 'abs');
%! assert (days (D), [2, -4; 2, 1; 1, 2; 1, 3]);
%!test
%! D = days ([1, 2; 1, 3; 2, -4; 2, 1]);
%! D = sortrows (D, -2, 'ComparisonMethod', 'abs');
%! assert (days (D), [2, -4; 1, 3; 1, 2; 2, 1]);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D);
%! X = [-2, NaN, 3; 1, 2, 2; 1, 3, 1; 1, 3, 2; 2, -4, 2; 2, 1, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, -2, 'MissingPlacement', 'first');
%! X = [-2, NaN, 3; 1, 3, 1; 1, 3, 2; 1, 2, 2; 2, 1, NaN; 2, -4, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, -2, 'MissingPlacement', 'last');
%! X = [1, 3, 1; 1, 3, 2; 1, 2, 2; 2, 1, NaN; 2, -4, 2; -2, NaN, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, 2, 'MissingPlacement', 'first');
%! X = [-2, NaN, 3; 2, -4, 2; 2, 1, NaN; 1, 2, 2; 1, 3, 1; 1, 3, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, 2, 'MissingPlacement', 'last');
%! X = [2, -4, 2; 2, 1, NaN; 1, 2, 2; 1, 3, 1; 1, 3, 2; -2, NaN, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, 'ComparisonMethod', 'abs', 'MissingPlacement', 'first');
%! X = [1, 2, 2; 1, 3, 1; 1, 3, 2; -2, NaN, 3; 2, 1, NaN; 2, -4, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, 'ComparisonMethod', 'abs', 'MissingPlacement', 'last');
%! X = [1, 2, 2; 1, 3, 1; 1, 3, 2; 2, 1, NaN; 2, -4, 2; -2, NaN, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2, 3]);
%! X = [-2, NaN, 3; 1, 3, 1; 1, 3, 2; 1, 2, 2; 2, 1, NaN; 2, -4, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [-1, -2, 3]);
%! X = [2, 1, NaN; 2, -4, 2; 1, 3, 1; 1, 3, 2; 1, 2, 2; -2, NaN, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2, -3]);
%! X = [-2, NaN, 3; 1, 3, 2; 1, 3, 1; 1, 2, 2; 2, 1, NaN; 2, -4, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2], {'ascend', 'descend'});
%! X = [-2, NaN, 3; 1, 3, 1; 1, 3, 2; 1, 2, 2; 2, 1, NaN; 2, -4, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2], {'descend', 'ascend'});
%! X = [2, -4, 2; 2, 1, NaN; 1, 2, 2; 1, 3, 1; 1, 3, 2; -2, NaN, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [-1, -2, 3], {'ascend', 'ascend', 'descend'});
%! X = [-2, NaN, 3; 1, 2, 2; 1, 3, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2, -3], string ({'ascend', 'ascend', 'descend'}));
%! X = [-2, NaN, 3; 1, 2, 2; 1, 3, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, string ({'ascend', 'ascend', 'descend'}));
%! X = [-2, NaN, 3; 1, 2, 2; 1, 3, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, string ({'ascend', 'ascend', 'descend'}));
%! X = [-2, NaN, 3; 1, 2, 2; 1, 3, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, 2, -3]);
%! X = [-2, NaN, 3; 1, 2, 2; 1, 3, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2, 3], 'MissingPlacement', 'first');
%! X = [-2, NaN, 3; 1, 3, 1; 1, 3, 2; 1, 2, 2; 2, 1, NaN; 2, -4, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [-1, -2, 3], 'MissingPlacement', 'first');
%! X = [2, 1, NaN; 2, -4, 2; 1, 3, 1; 1, 3, 2; 1, 2, 2; -2, NaN, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2, -3], 'MissingPlacement', 'first');
%! X = [-2, NaN, 3; 1, 3, 2; 1, 3, 1; 1, 2, 2; 2, 1, NaN; 2, -4, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2, 3], 'MissingPlacement', 'last');
%! X = [-2, NaN, 3; 1, 3, 1; 1, 3, 2; 1, 2, 2; 2, 1, NaN; 2, -4, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [-1, -2, 3], 'MissingPlacement', 'last');
%! X = [2, 1, NaN; 2, -4, 2; 1, 3, 1; 1, 3, 2; 1, 2, 2; -2, NaN, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2, -3], 'MissingPlacement', 'last');
%! X = [-2, NaN, 3; 1, 3, 2; 1, 3, 1; 1, 2, 2; 2, 1, NaN; 2, -4, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2, 3], 'MissingPlacement', 'first', 'ComparisonMethod', 'abs');
%! X = [1, 3, 1; 1, 3, 2; 1, 2, 2; -2, NaN, 3; 2, -4, 2; 2, 1, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [-1, -2, 3], 'MissingPlacement', 'first', 'ComparisonMethod', 'abs');
%! X = [-2, NaN, 3; 2, -4, 2; 2, 1, NaN; 1, 3, 1; 1, 3, 2; 1, 2, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2, -3], 'MissingPlacement', 'first', 'ComparisonMethod', 'abs');
%! X = [1, 3, 2; 1, 3, 1; 1, 2, 2; -2, NaN, 3; 2, -4, 2; 2, 1, NaN];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2, 3], 'MissingPlacement', 'last', 'ComparisonMethod', 'abs');
%! X = [1, 3, 1; 1, 3, 2; 1, 2, 2; 2, -4, 2; 2, 1, NaN; -2, NaN, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [-1, -2, 3], 'MissingPlacement', 'last', 'ComparisonMethod', 'abs');
%! X = [2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 1; 1, 3, 2; 1, 2, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2, -3], 'MissingPlacement', 'last', 'ComparisonMethod', 'abs');
%! X = [1, 3, 2; 1, 3, 1; 1, 2, 2; 2, -4, 2; 2, 1, NaN; -2, NaN, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2], {'ascend', 'descend'}, 'MissingPlacement', 'first');
%! X = [-2, NaN, 3; 1, 3, 1; 1, 3, 2; 1, 2, 2; 2, 1, NaN; 2, -4, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2], {'descend', 'ascend'}, 'MissingPlacement', 'last');
%! X = [2, -4, 2; 2, 1, NaN; 1, 2, 2; 1, 3, 1; 1, 3, 2; -2, NaN, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [-1, -2, 3], {'ascend', 'ascend', 'descend'}, ...
%!               'ComparisonMethod', 'abs', 'MissingPlacement', 'first');
%! X = [1, 2, 2; 1, 3, 2; 1, 3, 1; -2, NaN, 3; 2, 1, NaN; 2, -4, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2, -3], {'ascend', 'ascend', 'descend'}, ...
%!               'ComparisonMethod', 'abs', 'MissingPlacement', 'first');
%! X = [1, 2, 2; 1, 3, 2; 1, 3, 1; -2, NaN, 3; 2, 1, NaN; 2, -4, 2];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [-1, -2, 3], {'ascend', 'ascend', 'descend'}, ...
%!               'ComparisonMethod', 'abs', 'MissingPlacement', 'last');
%! X = [1, 2, 2; 1, 3, 2; 1, 3, 1; 2, 1, NaN; 2, -4, 2; -2, NaN, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, -2, -3], {'ascend', 'ascend', 'descend'}, ...
%!               'ComparisonMethod', 'abs', 'MissingPlacement', 'last');
%! X = [1, 2, 2; 1, 3, 2; 1, 3, 1; 2, 1, NaN; 2, -4, 2; -2, NaN, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, {'ascend', 'ascend', 'descend'}, 'ComparisonMethod', 'abs');
%! X = [1, 2, 2; 1, 3, 2; 1, 3, 1; 2, 1, NaN; 2, -4, 2; -2, NaN, 3];
%! assert (days (D), X);
%!test
%! D = days ([1, 2, 2; 1, 3, 1; 2, -4, 2; 2, 1, NaN; -2, NaN, 3; 1, 3, 2]);
%! D = sortrows (D, [1, 2, -3], 'ComparisonMethod', 'abs');
%! X = [1, 2, 2; 1, 3, 2; 1, 3, 1; 2, 1, NaN; 2, -4, 2; -2, NaN, 3];
%! assert (days (D), X);

################################################################################
##                  ** Reference and Assignment Operations **                 ##
################################################################################
##                             Available Methods                              ##
##                                                                            ##
## 'end'              'subsref'          'subsasgn'                           ##
##                                                                            ##
################################################################################

%!test
%! X = magic (3);
%! D = days (X);
%! assert (days (D(:, end)), X(:,end));
%!test
%! X = magic (3);
%! D = days (X);
%! assert (days (D([1:end-1], end)), [6; 7]);

%!test
%! D = duration ([1:5], 0, 0);
%! out = D([2,3]);
%! assert (size (out), [1, 2]);
%! assert (hours (out), [2, 3]);
%!test
%! D = duration ([1:5], 0, 0);
%! assert (D.Format, 'hh:mm:ss');
%!test
%! D = duration ([1:5], 0, 0, 'Format', 'hh:mm');
%! assert (D.Format, 'hh:mm');
%!test
%! D = duration ([1:5], 0, 0, 'Format', 'y');
%! assert (D.Format, 'y');
%!error<duration.subsref: '{}' invalid indexing for referencing values. Use '\(\)' instead.> ...
%! D = duration ([1:5], 0, 0); D{1}
%!error<duration.subsref: unrecognized property: 'form'> ...
%! D = duration ([1:5], 0, 0); D.form

%!test
%! D = duration ([1:5], 0, 0);
%! D([2,3]) = [4, 5];
%! assert (hours (D), [1, 96, 120, 4, 5]);
%!test
%! D = duration ([1:5], 0, 0);
%! D([2,3]) = hours ([4, 5]);
%! assert (hours (D), [1, 4, 5, 4, 5]);
%!test
%! D = days ([1:5]);
%! D([2,3]) = {'12:23:42', '00:12:23'};
%! assert (days (D), [1, 0.51646, 0.0085995, 4, 5], 1e-5);
%!test
%! D = days ([1:5]);
%! D([2,3]) = string ({'12:23:42', '00:12:23'});
%! assert (days (D), [1, 0.51646, 0.0085995, 4, 5], 1e-5);
%!test
%! D = days ([1:5]);
%! D([2,3]) = ['12:23:42'; '00:12:23'];
%! assert (days (D), [1, 0.51646, 0.0085995, 4, 5], 1e-5);
%!test
%! D = days ([1:5]);
%! D([2,3]) = {'05:12:00:00', '01:00:00:00'};
%! assert (days (D), [1, 5.5, 1, 4, 5]);
%!test
%! D = days ([1:5]);
%! D([2,3]) = string ({'05:12:00:00', '01:00:00:00'});
%! assert (days (D), [1, 5.5, 1, 4, 5]);
%!test
%! D = days ([1:5]);
%! D([2,3]) = ['05:12:00:00'; '01:00:00:00'];
%! assert (days (D), [1, 5.5, 1, 4, 5]);
%!test
%! D = days ([1:5]);
%! D([2,3]) = NaN;
%! assert (days (D), [1, NaN, NaN, 4, 5]);
%! assert (dispstrings (D), {'1 day', 'NaN days', 'NaN days', '4 days', '5 days'});
%!test
%! D = days ([1:5]);
%! D([1:3]) = missing;
%! assert (days (D), [NaN, NaN, NaN, 4, 5]);
%! assert (dispstrings (D), {'NaN days', 'NaN days', 'NaN days', '4 days', '5 days'});
%!test
%! D = days ([1:5]);
%! D([2,3]) = [Inf, -Inf];
%! assert (days (D), [1, Inf, -Inf, 4, 5]);
%! assert (dispstrings (D), {'1 day', 'Inf days', '-Inf days', '4 days', '5 days'});
%!test
%! D = days ([1:5]);
%! D([1:3]) = 2;
%! assert (days (D), [2, 2, 2, 4, 5]);
%!test
%! D = days ([1:5]);
%! D([1:3]) = [NaN, 2, 3];
%! assert (days (D), [NaN, 2, 3, 4, 5]);
%!test
%! D = duration (0, [1:5], 0);
%! D([1:3]) = [NaN, 2, 3];
%! assert (minutes (D), [NaN, 48 * 60, 72 * 60, 4, 5]);
%! assert (dispstrings (D), {'NaN', '48:00:00', '72:00:00', '00:04:00', '00:05:00'});
%!error<duration.subsasgn: chained subscripts not allowed.> ...
%! D = duration (); D(1)(1) = 1
%!error<duration.subsasgn: assignment value must be a duration array, a numeric array of days, or a text represention of durations.> ...
%! D = duration (); D(1) = {1}
%!error<duration.subsasgn: '{}' invalid indexing for assigning values. Use '\(\)' instead.> ...
%! D = duration ([1:5], 0, 0); D{1} = 1
%!error<duration.subsasgn: unrecognized property: 'form'> ...
%! D = duration ([1:5], 0, 0); D.form = 'f'
%!error<duration.subsasgn: 'Format' must be a character vector or a string scalar.> ...
%! D = duration ([1:5], 0, 0); D.Format = 3
%!error<duration.subsasgn: 'Format' must be a character vector or a string scalar.> ...
%! D = duration ([1:5], 0, 0); D.Format = ['y';'d']
%!error<duration.subsasgn: 'Format' must be a character vector or a string scalar.> ...
%! D = duration ([1:5], 0, 0); D.Format = string ({'mm:ss', 'hh:mm'})
%!error<duration.subsasgn: invalid display format.> ...
%! D = duration ([1:5], 0, 0); D.Format = 't'
%!error<duration.subsasgn: invalid display format.> ...
%! D = duration ([1:5], 0, 0); D.Format = 'd.h.S'
%!error<duration.subsasgn: invalid display format.> ...
%! D = duration ([1:5], 0, 0); D.Format = 's.SS'
%!error<duration.subsasgn: 'hh:mm' display format cannot indicate fractional second digits.> ...
%! D = duration ([1:5], 0, 0); D.Format = 'hh:mm.SS'
%!error<duration.subsasgn: invalid display format for fractional second digits.> ...
%! D = duration ([1:5], 0, 0); D.Format = 'hh:mm.SM'
%!error<duration.subsasgn: more than nine fractional second digits in display format.> ...
%! D = duration ([1:5], 0, 0); D.Format = 'hh:mm:ss.SSSSSSSSSS'

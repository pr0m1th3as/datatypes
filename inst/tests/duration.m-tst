%! D = sort (D, 1, 'descend', 'MissingPlacement', 'last', 'ComparisonMethod', 'abs');
%! X = [2, -4, 3; 2, 3, 2; -2, 3, 2; 1, 2, 2; 1, 1, 1; 1, NaN, NaN];
%! assert (days (D), X);

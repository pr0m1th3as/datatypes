%! D = sort (D, 2, 'descend', 'MissingPlacement', 'first');
%! X = [2, 2, 1; 3, 1, 1; 2, 2, -4; NaN, 2, 1; NaN, 3, -2; 3, 2, 1];
%! assert (days (D), X);
%!test

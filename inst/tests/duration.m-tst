################################################################################
##                 ** Create and convert 'duration' type **                   ##
################################################################################
##                             Available Methods                              ##
##                                                                            ##
## 'duration'         'dispstrings'      'cellstr'          'char'            ##
## 'datevec'          'hms'              'years'            'days'            ##
## 'hours'            'minutes'          'seconds'          'milliseconds'    ##
##                                                                            ##
################################################################################

%!assert (isscalar (duration ()), true)
%!assert (isempty (duration ()), false)
%!assert (class (duration), 'duration')
%!assert (dispstrings (duration ()), {'00:00:00'})
%!assert (size (duration (zeros (4, 3))), [4, 1])
%!assert (isempty (duration (ones (0, 3))), true)
%!assert (seconds (duration ([0, 0, 15])), 15)
%!assert (minutes (duration ([0, 50, 30])), 50.5)
%!assert (hours (duration ([1, 0, 3600; 5, 60, 0])), [2; 6])
%!assert (seconds (duration ('30:15', 'InputFormat', 'mm:ss')), 1815)
%!assert (hours (duration ({'01:00', '02:30'}, 'InputFormat', 'hh:mm')), [1, 2.5])
%!assert (minutes (duration ({'01:00:30'}, 'InputFormat', 'hh:mm:ss')), 60.5)
%!assert (minutes (duration ({'01:00:45'}, 'InputFormat', 'hh:mm:ss')), 60.75)
%!assert (days (duration ({'24:00:00'}, 'InputFormat', 'hh:mm:ss')), 1)
%!assert (days (duration ({'1:12:00:00'}, 'InputFormat', 'dd:hh:mm:ss')), 1.5)
%!assert (seconds (duration (0, 0, 15)), 15)
%!assert (seconds (duration (0, zeros (4), 15)), ones (4) * 15)
%!assert (minutes (duration (0, 50, 30)), 50.5)
%!assert (minutes (duration (0, 40:50, 30)), [40:50] + 0.5)
%!assert (seconds (duration (0, 0, 0, 15)), 0.015)
%!assert (size (duration (ones (2, 4, 3), 0, 0)), [2, 4, 3])
%!assert (size (duration (0, ones (2, 3, 4), 0)), [2, 3, 4])
%!assert (size (duration (zeros (4), zeros (4), 0, 0)), [4, 4])
%!assert (size (duration (zeros (4), 0, 0, zeros (4))), [4, 4])
%!error<duration: 'Format' must be a character vector or a string scalar.> ...
%! duration (0, 0, 0, 'Format', 5)
%!error<duration: 'Format' must be a character vector or a string scalar.> ...
%! duration (0, 0, 0, 'Format', {'mm:ss'})
%!error<duration: 'Format' must be a character vector or a string scalar.> ...
%! duration (0, 0, 0, 'Format', string ({'mm:ss', 'hh:mm:ss'}))
%!error<duration: invalid display format.> duration (0, 0, 0, 'Format', 't')
%!error<duration: invalid display format.> duration (0, 0, 0, 'Format', 'd.h.S')
%!error<duration: invalid display format.> duration (0, 0, 0, 'Format', 's.SS')
%!error<duration: 'hh:mm' display format cannot indicate fractional second digits.> ...
%! duration (0, 0, 0, 'Format', 'hh:mm.SS')
%!error<duration: invalid display format for fractional second digits.> ...
%! duration (0, 0, 0, 'Format', 'hh:mm.SM')
%!error<duration: more than nine fractional second digits in display format.> ...
%! duration (0, 0, 0, 'Format', 'hh:mm:ss.SSSSSSSSSS')
%!error<duration: 'InputFormat' must be a character vector or a string scalar.> ...
%! duration (0, 0, 0, 'InputFormat', {'hh:mm'})
%!error<duration: 'InputFormat' must be a character vector or a string scalar.> ...
%! duration (0, 0, 0, 'InputFormat', string ({'hh:mm', 'hh:mm'}))
%!error<duration: invalid 'InputFormat'.> duration (0, 0, 0, 'InputFormat', 'hh:mmm')
%!error<duration: invalid 'InputFormat'.> duration (0, 0, 0, 'InputFormat', string ('hh:mmm'))
%!error<duration: 'hh:mm' input format cannot indicate fractional second digits.> ...
%! duration (0, 0, 0, 'InputFormat', 'hh:mm.SSS')
%!error<duration: invalid 'InputFormat' for fractional second digits.> ...
%! duration (0, 0, 0, 'InputFormat', string ('hh:mm:ss.SSM'))
%!error<duration: more than nine fractional second digits in 'InputFormat'.> ...
%! duration (0, 0, 0, 'InputFormat', string ('hh:mm:ss.SSSSSSSSSS'))
%!error<duration: more than nine fractional second digits in 'InputFormat'.> ...
%! duration (0, 0, 0, 'InputFormat', 'hh:mm:ss.SSSSSSSSSS')
%!error<duration: numeric X must be a matrix.> duration (ones (2, 2, 2))
%!error<duration: numeric X must be real.> duration (ones (2, 3) * i)
%!error<duration: X must have 3 columns.> duration (ones (2, 4))
%!error<duration: invalid type of single input data argument.> duration ({1})
%!error<duration: invalid type of single input data argument.> duration (struct ('a', 1))
%!error<duration: H, MI, and S must be numeric arrays.> duration ('a', 0, 0)
%!error<duration: H, MI, and S must be numeric arrays.> duration (0, 'a', 0)
%!error<duration: H, MI, and S must be numeric arrays.> duration (0, 0, 'a')
%!error<duration: H, MI, and S must be real.> duration (i, 0, 0)
%!error<duration: H, MI, and S must be real.> duration (0, i, 0)
%!error<duration: H, MI, and S must be real.> duration (0, 0, i)
%!error<duration: H, MI, and S must be of common size or scalars.> ...
%! duration (0, [0, 0], [0; 0])
%!error<duration: H, MI, S, and MS must be numeric arrays.> duration ('a', 0, 0, 0)
%!error<duration: H, MI, S, and MS must be numeric arrays.> duration (0, 'a', 0, 0)
%!error<duration: H, MI, S, and MS must be numeric arrays.> duration (0, 0, 'a', 0)
%!error<duration: H, MI, S, and MS must be numeric arrays.> duration (0, 0, 0, 'a')
%!error<duration: H, MI, S, and MS must be real.> duration (i, 0, 0, 0)
%!error<duration: H, MI, S, and MS must be real.> duration (0, i, 0, 0)
%!error<duration: H, MI, S, and MS must be real.> duration (0, 0, i, 0)
%!error<duration: H, MI, S, and MS must be real.> duration (0, 0, 0, i)
%!error<duration: H, MI, S, and MS must be of common size or scalars.> ...
%! duration (0, [0, 0], [0; 0], 0)
%!error<duration: invalid number of input arguments.> duration (1, 2, 3, 4, 5)
%!warning<duration: 'InputFormat' has no effect on numeric data.> ...
%! duration ([0, 0, 0], 'InputFormat', 'hh:mm');
%!warning<duration: 'InputFormat' has no effect on numeric data.> ...
%! duration (0, 0, 0, 'InputFormat', 'hh:mm');
%!warning<duration: 'InputFormat' has no effect on numeric data.> ...
%! duration (0, 0, 0, 0, 'InputFormat', 'hh:mm');

%!assert (dispstrings (years (1)), {'1 yr'})
%!assert (dispstrings (years (2)), {'2 yrs'})
%!assert (dispstrings (years ([1, 2, 2.4])), {'1 yr', '2 yrs', '2.4 yrs'})
%!assert (dispstrings (years ([1; 2; 2.4])), {'1 yr'; '2 yrs'; '2.4 yrs'})
%!assert (dispstrings (days (1)), {'1 day'})
%!assert (dispstrings (days (2)), {'2 days'})
%!assert (dispstrings (days ([1, 2, 2.4])), {'1 day', '2 days', '2.4 days'})
%!assert (dispstrings (days ([1; 2; 2.4])), {'1 day'; '2 days'; '2.4 days'})
%!assert (dispstrings (duration (36, 0, 0)), {'36:00:00'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'y')), {'0.00410686 yrs'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'd')), {'1.5 days'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'h')), {'36 hr'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'm')), {'2160 min'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 's')), {'129600 sec'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'dd:hh:mm:ss.SSSSS')), {'01:12:00:00.00000'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'hh:mm:ss.SSSSS')), {'36:00:00.00000'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'hh:mm:ss.SSSS')), {'36:00:00.0000'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'hh:mm:ss.SSS')), {'36:00:00.000'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'hh:mm:ss.SS')), {'36:00:00.00'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'hh:mm:ss.S')), {'36:00:00.0'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'hh:mm')), {'36:00'})
%!assert (dispstrings (duration (36, 0, 0.025, 'Format', 'hh:mm')), {'36:00'})
%!assert (dispstrings (duration (36, 0, 55.025, 'Format', 'hh:mm')), {'36:00'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'mm:ss.SSSSS')), {'2160:00.00000'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'mm:ss.SSSSSS')), {'2160:00.000000'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'mm:ss.SSSSSSS')), {'2160:00.0000000'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'mm:ss.SSSSSSSS')), {'2160:00.00000000'})
%!assert (dispstrings (duration (36, 0, 0, 'Format', 'mm:ss.SSSSSSSSS')), {'2160:00.000000000'})
%!assert (dispstrings (duration (0, 36, 0)), {'00:36:00'})
%!assert (dispstrings (duration (0, 36, 0, 'Format', 'y')), {'6.84477e-05 yrs'})
%!assert (dispstrings (duration (0, 36, 0, 'Format', 'd')), {'0.025 days'})
%!assert (dispstrings (duration (0, 36, 0, 'Format', 'h')), {'0.6 hr'})
%!assert (dispstrings (duration (0, 36, 0, 'Format', 'm')), {'36 min'})
%!assert (dispstrings (duration (0, 36, 0, 'Format', 's')), {'2160 sec'})
%!assert (dispstrings (duration (0, 36, 0.025, 'Format', 'dd:hh:mm:ss.SSSSS')), {'00:36:00.02500'})
%!assert (dispstrings (duration (0, 36, 0.025, 'Format', 'hh:mm:ss.SSSSS')), {'00:36:00.02500'})
%!assert (dispstrings (duration (0, 36, 0.025, 'Format', 'hh:mm:ss.SSSS')), {'00:36:00.0250'})
%!assert (dispstrings (duration (0, 36, 0.025, 'Format', 'hh:mm:ss.SSS')), {'00:36:00.025'})
%!assert (dispstrings (duration (0, 36, 0.025, 'Format', 'hh:mm:ss.SS')), {'00:36:00.02'})
%!assert (dispstrings (duration (0, 36, 0.025, 'Format', 'hh:mm:ss.S')), {'00:36:00.0'})
%!assert (dispstrings (duration (0, 36, 0.025, 'Format', 'hh:mm')), {'00:36'})
%!assert (dispstrings (duration (0, 36, 5.025, 'Format', 'hh:mm')), {'00:36'})
%!assert (dispstrings (duration (0, 36, 0.025, 'Format', 'mm:ss.SSSSS')), {'36:00.02500'})
%!assert (dispstrings (duration (0, 36, 0.025, 'Format', 'mm:ss.SSSSSS')), {'36:00.025000'})
%!assert (dispstrings (duration (0, 36, 0.025, 'Format', 'mm:ss.SSSSSSS')), {'36:00.0250000'})
%!assert (dispstrings (duration (0, 36, 0.025, 'Format', 'mm:ss.SSSSSSSS')), {'36:00.02500000'})
%!assert (dispstrings (duration (0, 36, 0.025, 'Format', 'mm:ss.SSSSSSSSS')), {'36:00.025000000'})

%!assert (cellstr (years (1)), {'1 yr'})
%!assert (cellstr (years (1), 'd'), {'365.243 days'})
%!assert (cellstr (years (2)), {'2 yrs'})
%!assert (cellstr (years (2), 'd'), {'730.485 days'})
%!assert (cellstr (days (1)), {'1 day'})
%!assert (cellstr (days (1), 'y'), {'0.00273791 yrs'})
%!assert (cellstr (days (2), 'm'), {'2880 min'})
%!assert (cellstr (duration (36, 0, 0)), {'36:00:00'})
%!assert (cellstr (duration (36, 0, 0), 'y'), {'0.00410686 yrs'})
%!assert (cellstr (duration (36, 0, 0), 'd'), {'1.5 days'})
%!assert (cellstr (duration (36, 0, 0), 'h'), {'36 hr'})
%!assert (cellstr (duration (36, 0, 0), 'm'), {'2160 min'})
%!assert (cellstr (duration (36, 0, 0), 's'), {'129600 sec'})
%!assert (cellstr (duration (36, 0, 0), 'dd:hh:mm:ss.SSSSS'), {'01:12:00:00.00000'})
%!assert (cellstr (duration (36, 0, 0), 'hh:mm:ss.SSSSS'), {'36:00:00.00000'})
%!assert (cellstr (duration (36, 0, 0), 'hh:mm:ss.SSSS'), {'36:00:00.0000'})
%!assert (cellstr (duration (36, 0, 0), 'hh:mm:ss.SSS'), {'36:00:00.000'})
%!assert (cellstr (duration (36, 0, 0), 'hh:mm:ss.SS'), {'36:00:00.00'})
%!assert (cellstr (duration (36, 0, 0), 'hh:mm:ss.S'), {'36:00:00.0'})
%!assert (cellstr (duration (36, 0, 0), 'hh:mm'), {'36:00'})
%!assert (cellstr (duration (36, 0, 0.025), 'hh:mm'), {'36:00'})
%!assert (cellstr (duration (36, 0, 55.025), 'hh:mm'), {'36:00'})
%!assert (cellstr (duration (36, 0, 0), 'mm:ss.SSSSS'), {'2160:00.00000'})
%!assert (cellstr (duration (36, 0, 0), 'mm:ss.SSSSSS'), {'2160:00.000000'})
%!assert (cellstr (duration (36, 0, 0), 'mm:ss.SSSSSSS'), {'2160:00.0000000'})
%!assert (cellstr (duration (36, 0, 0), 'mm:ss.SSSSSSSS'), {'2160:00.00000000'})
%!assert (cellstr (duration (36, 0, 0), 'mm:ss.SSSSSSSSS'), {'2160:00.000000000'})
%!assert (cellstr (duration (0, 36, 0)), {'00:36:00'})
%!assert (cellstr (duration (0, 36, 0), 'y'), {'6.84477e-05 yrs'})
%!assert (cellstr (duration (0, 36, 0), 'd'), {'0.025 days'})
%!assert (cellstr (duration (0, 36, 0), 'h'), {'0.6 hr'})
%!assert (cellstr (duration (0, 36, 0), 'm'), {'36 min'})
%!assert (cellstr (duration (0, 36, 0), 's'), {'2160 sec'})
%!assert (cellstr (duration (0, 36, 0.025), 'dd:hh:mm:ss.SSSSS'), {'00:36:00.02500'})
%!assert (cellstr (duration (0, 36, 0.025), 'hh:mm:ss.SSSSS'), {'00:36:00.02500'})
%!assert (cellstr (duration (0, 36, 0.025), 'hh:mm:ss.SSSS'), {'00:36:00.0250'})
%!assert (cellstr (duration (0, 36, 0.025), 'hh:mm:ss.SSS'), {'00:36:00.025'})
%!assert (cellstr (duration (0, 36, 0.025), 'hh:mm:ss.SS'), {'00:36:00.02'})
%!assert (cellstr (duration (0, 36, 0.025), 'hh:mm:ss.S'), {'00:36:00.0'})
%!assert (cellstr (duration (0, 36, 0.025), 'hh:mm'), {'00:36'})
%!assert (cellstr (duration (0, 36, 5.025), 'hh:mm'), {'00:36'})
%!assert (cellstr (duration (0, 36, 0.025), 'mm:ss.SSSSS'), {'36:00.02500'})
%!assert (cellstr (duration (0, 36, 0.025), 'mm:ss.SSSSSS'), {'36:00.025000'})
%!assert (cellstr (duration (0, 36, 0.025), 'mm:ss.SSSSSSS'), {'36:00.0250000'})
%!assert (cellstr (duration (0, 36, 0.025), 'mm:ss.SSSSSSSS'), {'36:00.02500000'})
%!assert (cellstr (duration (0, 36, 0.025), 'mm:ss.SSSSSSSSS'), {'36:00.025000000'})
%!error<duration.cellstr: FORMAT must be a character vector or a string scalar.> ...
%! cellstr (days (2), string ({'m', 'y'}))
%!error<duration.cellstr: FORMAT must be a character vector or a string scalar.> ...
%! cellstr (days (2), ['m'; 'y'])
%!error<duration.cellstr: FORMAT must be a character vector or a string scalar.> ...
%! cellstr (days (2), {'m'})
%!error<duration.cellstr: FORMAT must be a character vector or a string scalar.> ...
%! cellstr (days (2), 2)
%!error<duration.cellstr: invalid display format.> cellstr (duration (0, 0, 0), 't')
%!error<duration.cellstr: invalid display format.> cellstr (duration (0, 0, 0), 'd.h.S')
%!error<duration.cellstr: invalid display format.> cellstr (duration (0, 0, 0), 's.SS')
%!error<duration.cellstr: 'hh:mm' display format cannot indicate fractional second digits.> ...
%! cellstr (duration (0, 0, 0), 'hh:mm.SS')
%!error<duration.cellstr: invalid display format for fractional second digits.> ...
%! cellstr (duration (0, 0, 0), 'hh:mm.SM')
%!error<duration.cellstr: more than nine fractional second digits in display format.> ...
%! cellstr (duration (0, 0, 0), 'hh:mm:ss.SSSSSSSSSS')

%!assert (char (years (1)), '1 yr')
%!assert (char (years ([1, 2])), ['1 yr '; '2 yrs'])
%!assert (char (years (1), 'd'), '365.243 days')
%!assert (char (years (2)), '2 yrs')
%!assert (char (years (2), 'd'), '730.485 days')
%!assert (char (days (1)), '1 day')
%!assert (char (days ([1; 2])), ['1 day '; '2 days'])
%!assert (char (days (1), 'y'), '0.00273791 yrs')
%!assert (char (days (2), 'm'), '2880 min')
%!assert (char (duration (36, 0, 0)), '36:00:00')
%!assert (char (duration (36, 0, 0), 'y'), '0.00410686 yrs')
%!assert (char (duration (36, 0, 0), 'd'), '1.5 days')
%!assert (char (duration (36, 0, 0), 'h'), '36 hr')
%!assert (char (duration (36, 0, 0), 'm'), '2160 min')
%!assert (char (duration (36, 0, 0), 's'), '129600 sec')
%!assert (char (duration (36, 0, 0), 'dd:hh:mm:ss.SSSSS'), '01:12:00:00.00000')
%!assert (char (duration (36, 0, 0), 'hh:mm:ss.SSSSS'), '36:00:00.00000')
%!assert (char (duration (36, 0, 0), 'hh:mm:ss.SSSS'), '36:00:00.0000')
%!assert (char (duration (36, 0, 0), 'hh:mm:ss.SSS'), '36:00:00.000')
%!assert (char (duration (36, 0, 0), 'hh:mm:ss.SS'), '36:00:00.00')
%!assert (char (duration (36, 0, 0), 'hh:mm:ss.S'), '36:00:00.0')
%!assert (char (duration (36, 0, 0), 'hh:mm'), '36:00')
%!assert (char (duration (36, 0, 0.025), 'hh:mm'), '36:00')
%!assert (char (duration (36, 0, 55.025), 'hh:mm'), '36:00')
%!assert (char (duration (36, 0, 0), 'mm:ss.SSSSS'), '2160:00.00000')
%!assert (char (duration (36, 0, 0), 'mm:ss.SSSSSS'), '2160:00.000000')
%!assert (char (duration (36, 0, 0), 'mm:ss.SSSSSSS'), '2160:00.0000000')
%!assert (char (duration (36, 0, 0), 'mm:ss.SSSSSSSS'), '2160:00.00000000')
%!assert (char (duration (36, 0, 0), 'mm:ss.SSSSSSSSS'), '2160:00.000000000')
%!assert (char (duration (0, 36, 0)), '00:36:00')
%!assert (char (duration (0, 36, 0), 'y'), '6.84477e-05 yrs')
%!assert (char (duration (0, 36, 0), 'd'), '0.025 days')
%!assert (char (duration (0, 36, 0), 'h'), '0.6 hr')
%!assert (char (duration (0, 36, 0), 'm'), '36 min')
%!assert (char (duration (0, 36, 0), 's'), '2160 sec')
%!assert (char (duration (0, 36, 0.025), 'dd:hh:mm:ss.SSSSS'), '00:36:00.02500')
%!assert (char (duration (0, 36, 0.025), 'hh:mm:ss.SSSSS'), '00:36:00.02500')
%!assert (char (duration (0, 36, 0.025), 'hh:mm:ss.SSSS'), '00:36:00.0250')
%!assert (char (duration (0, 36, 0.025), 'hh:mm:ss.SSS'), '00:36:00.025')
%!assert (char (duration (0, 36, 0.025), 'hh:mm:ss.SS'), '00:36:00.02')
%!assert (char (duration (0, 36, 0.025), 'hh:mm:ss.S'), '00:36:00.0')
%!assert (char (duration (0, 36, 0.025), 'hh:mm'), '00:36')
%!assert (char (duration (0, 36, 5.025), 'hh:mm'), '00:36')
%!assert (char (duration (0, 36, 0.025), 'mm:ss.SSSSS'), '36:00.02500')
%!assert (char (duration (0, 36, 0.025), 'mm:ss.SSSSSS'), '36:00.025000')
%!assert (char (duration (0, 36, 0.025), 'mm:ss.SSSSSSS'), '36:00.0250000')
%!assert (char (duration (0, 36, 0.025), 'mm:ss.SSSSSSSS'), '36:00.02500000')
%!assert (char (duration (0, 36, 0.025), 'mm:ss.SSSSSSSSS'), '36:00.025000000')
%!error<duration.char: FORMAT must be a character vector or a string scalar.> ...
%! char (days (2), string ({'m', 'y'}))
%!error<duration.char: FORMAT must be a character vector or a string scalar.> ...
%! char (days (2), ['m'; 'y'])
%!error<duration.char: FORMAT must be a character vector or a string scalar.> ...
%! char (days (2), {'m'})
%!error<duration.char: FORMAT must be a character vector or a string scalar.> ...
%! char (days (2), 2)
%!error<duration.char: invalid display format.> char (duration (0, 0, 0), 't')
%!error<duration.char: invalid display format.> char (duration (0, 0, 0), 'd.h.S')
%!error<duration.char: invalid display format.> char (duration (0, 0, 0), 's.SS')
%!error<duration.char: 'hh:mm' display format cannot indicate fractional second digits.> ...
%! char (duration (0, 0, 0), 'hh:mm.SS')
%!error<duration.char: invalid display format for fractional second digits.> ...
%! char (duration (0, 0, 0), 'hh:mm.SM')
%!error<duration.char: more than nine fractional second digits in display format.> ...
%! char (duration (0, 0, 0), 'hh:mm:ss.SSSSSSSSSS')

%!test
%! [y, mo, d, h, mi, s] = datevec (years (1));
%! assert (y, 1);
%! assert (mo, 0);
%! assert (d, 0);
%! assert (h, 0);
%! assert (mi, 0);
%! assert (s, 0);
%!test
%! [y, mo, d, h, mi, s] = datevec (years (1.0258123));
%! assert (y, 1);
%! assert (mo, 0);
%! assert (d, 9);
%! assert (h, 10);
%! assert (mi, 15);
%! assert (s, 57.5121, 1E-4);
%!test
%! [y, mo, d, h, mi, s] = datevec (years (1.5));
%! assert (y, 1);
%! assert (mo, 0);
%! assert (d, 182);
%! assert (h, 14);
%! assert (mi, 54);
%! assert (s, 36, 1e-8);
%!test
%! [y, mo, d, h, mi, s] = datevec (days (1));
%! assert (y, 0);
%! assert (mo, 0);
%! assert (d, 1);
%! assert (h, 0);
%! assert (mi, 0);
%! assert (s, 0);
%!test
%! [y, mo, d, h, mi, s] = datevec (days (1.0258123));
%! assert (y, 0);
%! assert (mo, 0);
%! assert (d, 1);
%! assert (h, 0);
%! assert (mi, 37);
%! assert (s, 10.1827, 1E-4);
%!test
%! [y, mo, d, h, mi, s] = datevec (days (1.5));
%! assert (y, 0);
%! assert (mo, 0);
%! assert (d, 1);
%! assert (h, 12);
%! assert (mi, 0);
%! assert (s, 0, 1e-8);
%!assert (datevec (years (1)), [1, 0, 0, 0, 0, 0])
%!assert (datevec (years (1.0258123)), [1, 0, 9, 10, 15, 57.5121], 1e-4)
%!assert (datevec (years (1.5)), [1, 0, 182, 14, 54, 36], 1e-8)
%!assert (datevec (days (1)), [0, 0, 1, 0, 0, 0])
%!assert (datevec (days (1.0258123)), [0, 0, 1, 0, 37, 10.1827], 1e-4)
%!assert (datevec (days (1.5)), [0, 0, 1, 12, 0, 0])
%!test
%! [y, mo, d, h, mi, s] = datevec (days (magic (3)));
%! assert (y, zeros (3));
%! assert (mo, zeros (3));
%! assert (d, magic (3));
%! assert (h, zeros (3));
%! assert (mi, zeros (3));
%! assert (s, zeros (3));
%!test
%! DV = datevec (days (magic (3)));
%! out = zeros (9, 6);
%! out(:,3) = magic (3)(:);
%! assert (DV, out);
%!test
%! [y, mo, d, h, mi, s] = datevec (days (ones (2, 3, 4)));
%! assert (y, zeros (2, 3, 4));
%! assert (mo, zeros (2, 3, 4));
%! assert (d, ones (2, 3, 4));
%! assert (h, zeros (2, 3, 4));
%! assert (mi, zeros (2, 3, 4));
%! assert (s, zeros (2, 3, 4));
%!test
%! DV = datevec (days (ones (2, 3, 4)));
%! out = zeros (24, 6);
%! out(:,3) = ones (24, 1);
%! assert (DV, out);
%!test
%! DV = datevec (years (reshape ([1:24], 2, 3, 4)));
%! out = zeros (24, 6);
%! out(:,1) = [1:24]';
%! assert (DV, out);
%!test
%! DV = datevec (days (reshape ([1:24], 2, 3, 4)));
%! out = zeros (24, 6);
%! out(:,3) = [1:24]';
%! assert (DV, out);
%!test
%! DV = datevec (hours (reshape ([1:24], 2, 3, 4)));
%! out = zeros (24, 6);
%! out(:,4) = [1:23,0]';
%! out(24,3) = 1;
%! assert (DV, out);
%!test
%! DV = datevec (minutes (reshape ([1:24], 2, 3, 4)));
%! out = zeros (24, 6);
%! out(:,5) = [1:24]';
%! assert (DV, out);
%!test
%! DV = datevec (seconds (reshape ([1:24], 2, 3, 4)));
%! out = zeros (24, 6);
%! out(:,6) = [1:24]';
%! assert (DV, out, 2e-15);
%!test
%! DV = datevec (milliseconds (reshape ([1:24], 2, 3, 4)));
%! out = zeros (24, 6);
%! out(:,6) = 1e-3 * [1:24]';
%! assert (DV, out, 2e-15);
%!test
%! X = reshape ([1:24], 2, 3, 4);
%! X([12,17]) = NaN;
%! DV = datevec (days (X));
%! out = zeros (24, 6);
%! out(:, 3) = [1:24]';
%! out([12,17],:) = NaN;
%! assert (DV, out);
%!test
%! X = reshape ([1:24], 2, 3, 4);
%! X([12,17]) = NaN;
%! [y, mo, d, h, mi, s] = datevec (days (X));
%! y_out = mo_out = h_out = mi_out = s_out = zeros (2, 3, 4);
%! d_out = X;
%! y_out([12,17]) = mo_out([12,17]) = NaN;
%! h_out([12,17]) = mi_out([12,17]) = s_out([12,17]) = NaN;
%! assert (y, y_out);
%! assert (mo, mo_out);
%! assert (d, d_out);
%! assert (h, h_out);
%! assert (mi, mi_out);
%! assert (s, s_out);

%!assert (hms (hours ([1:5])), [1:5])
%!assert (hms (days ([1:5])), 24 * [1:5])
%!assert (hms (hours (reshape ([1:24], 2, 3, 4))), reshape ([1:24], 2, 3, 4))
%!test
%! [h, m, s] = hms (days (0.25 * reshape ([1:24], 2, 3, 4)));
%! assert (h, 6 * reshape ([1:24], 2, 3, 4));
%! assert (m, zeros (2, 3, 4));
%! assert (s, zeros (2, 3, 4));
%!test
%! [h, m, s] = hms (years (0.25 * reshape ([1:24], 2, 3, 4)));
%! h_out = fix (hours (years (0.25 * reshape ([1:24], 2, 3, 4))));
%! assert (h, h_out);
%! m_out = fix (minutes (years (0.25 * reshape ([1:24], 2, 3, 4)))) - h_out * 60;
%! assert (m, m_out);
%! s_out = round (seconds (years (0.25 * reshape ([1:24], 2, 3, 4))));
%! assert (s, s_out - (h_out * 3600 + m_out * 60), 5e-8);
%!test
%! [h, m, s] = hms (hours ([1:5]));
%! assert (m, zeros (1, 5));
%! assert (s, zeros (1, 5));
%!test
%! [h, m, s] = hms (minutes ([1:5]));
%! assert (h, zeros (1, 5));
%! assert (m, [1:5]);
%! assert (s, zeros (1, 5));
%!test
%! [h, m, s] = hms (seconds ([1:5]));
%! assert (h, zeros (1, 5));
%! assert (m, zeros (1, 5));
%! assert (s, [1:5]);
%!error<duration.hms: too many output arguments.> [h, m, s, ms] = hms (days (1))

################################################################################
##                         ** Summary Information **                          ##
################################################################################
##                             Available Methods                              ##
##                                                                            ##
## 'size'             'ndims'            'numel'            'nnz'             ##
## 'length'           'keyHash'                                               ##
##                                                                            ##
################################################################################

%!assert (size (duration), [1, 1])
%!assert (size (days ([])), [0, 0])
%!assert (size (days (ones (2, 0, 3, 4))), [2, 0, 3, 4])
%!assert (size (duration (ones (2, 4), 0, 0)), [2, 4])
%!assert (size (duration (ones (2, 4, 1, 1), 0, 0)), [2, 4])
%!assert (size (duration (ones (2, 4, 1, 0), 0, 0)), [2, 4, 1, 0])
%!assert (size (duration (zeros (6, 3))), [6, 1])

%!assert (ndims (duration), 2)
%!assert (ndims (days ([])), 2)
%!assert (ndims (days (ones (2, 0, 3, 4))), 4)
%!assert (ndims (duration (ones (2, 4), 0, 0)), 2)
%!assert (ndims (duration (zeros (6, 3))), 2)

%!assert (numel (duration), 1)
%!assert (numel (days ([])), 1)
%!assert (numel (days (ones (2, 0, 3, 4))), 1)
%!assert (numel (duration (ones (2, 4), 0, 0)), 1)
%!assert (numel (duration (zeros (6, 3))), 1)

%!assert (nnz (days ([])), 0)
%!assert (nnz (duration), 0)
%!assert (nnz (days (ones (2, 0, 3, 4))), 0)
%!assert (nnz (days (zeros (2, 0, 3, 4))), 0)
%!assert (nnz (days (zeros (2, 1, 3, 4))), 0)
%!assert (nnz (days (ones (2, 1, 3, 4))), 24)
%!assert (nnz (days ([1, 4, 0, 9, 0, 8])), 4)
%!assert (nnz (days ([1, 4, 0; 9, 0, 8])), 4)

%!assert (length (duration (1, 1, 1)), 1)
%!assert (length (duration (0, 0, 0)), 1)
%!assert (length (duration (0:5, 0, 0)), 6)
%!assert (length (duration ([0, 0, 0, 1, 1], 0, 0)), 5)
%!assert (length (duration (ones (2, 3, 4), 0, 0)), 4)
%!assert (length (duration (ones (2, 10, 4), 0, 0)), 10)

%!assert (keyHash (duration), uint64 (8095976253982599603))
%!assert (keyHash (duration (0, 0, 0)), uint64 (8095976253982599603))
%!assert (keyHash (duration ([], [], [])), uint64 (14859204025010592219))
%!assert (keyHash (duration (1, 1, 1)), uint64 (13776124020415645612))
%!test
%! key = keyHash (duration ([1, 2; 3, 4], 1, 1));
%! assert (key, uint64 (9389203521563080232));
%!test
%! key = keyHash (duration (0, 0, 0, [1, 2, 3]));
%! assert (key, uint64 (7422929858764574817));
%!test
%! base_key = uint64 (2342124352342344234);
%! key = keyHash (duration (0, 0, 0, [1, 2, 3]), base_key);
%! assert (key, uint64 (13938388645620099040));
%!error<duration.keyHash: BASE must be a UINT64 scalar.> ...
%! keyHash (duration (0, 0, 0), uint64 ([1, 2]))
%!error<duration.keyHash: BASE must be a UINT64 scalar.> ...
%! keyHash (duration (0, 0, 0), 2231107818551636405)

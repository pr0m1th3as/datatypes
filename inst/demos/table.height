%!demo
%! ## `height` counts rows, independent of how many columns each variable spans.
%! ## Here `BloodPressure` occupies two columns, yet the table still has 5 rows.
%!
%! Age = [38; 43; 38; 40; 49];
%! BloodPressure = [124, 93; 109, 77; 125, 83; 117, 75; 122, 80];
%! T = table (Age, BloodPressure);
%! height (T)
%!
%! ## It is the row count you index against, so `height` is the natural bound
%! ## for a loop or a final-row reference.
%! T(height (T), :)
